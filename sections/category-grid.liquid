<section class="section category-grid-section container">
  <div class="section-header text-center" style="margin-bottom: 2rem;">
    <span class="section-eyebrow font-display" style="display:block; color: var(--color-primary); font-weight:700; font-size:0.85rem; letter-spacing:3px; text-transform:uppercase; margin-bottom:8px;">Browse by Type</span>
    <h2 class="font-display" style="font-size: clamp(1.5rem, 3vw, 2.2rem); text-transform: uppercase; letter-spacing: 1px;">COLLECTIONS</h2>
  </div>
  <div class="cat-grid">
    {%- if section.blocks.size > 0 -%}
      {%- for block in section.blocks -%}
        {%- assign lbl = block.settings.tile_label -%}
        {%- assign handle = lbl | handleize -%}
        {%- assign coll = collections[handle] -%}
        {%- assign auto_img = coll.image | default: coll.products.first.featured_image -%}
        {%- assign final_img = block.settings.tile_image | default: auto_img -%}
        <a href="{{ block.settings.tile_link | default: coll.url | default: '/collections/all' }}" class="cat-tile reveal">
          <div class="cat-tile__img">
            {%- if final_img != blank -%}
              <img src="{{ final_img | image_url: width: 500 }}" alt="{{ lbl | escape }}" loading="lazy">
            {%- else -%}
              <div class="cat-tile__fallback">
                <svg viewBox="0 0 80 80" fill="none" width="48" height="48">
                  <rect x="12" y="12" width="22" height="22" rx="3" fill="rgba(255,208,0,0.25)" stroke="#FFD000" stroke-width="1.5"/>
                  <rect x="34" y="12" width="22" height="22" rx="3" fill="rgba(255,208,0,0.15)" stroke="#FFD000" stroke-width="1.5"/>
                  <rect x="12" y="34" width="22" height="22" rx="3" fill="rgba(26,159,224,0.2)" stroke="#1A9FE0" stroke-width="1.5"/>
                  <rect x="34" y="34" width="22" height="22" rx="3" fill="rgba(26,159,224,0.1)" stroke="#1A9FE0" stroke-width="1.5"/>
                </svg>
              </div>
            {%- endif -%}
          </div>
          <span class="cat-tile__label font-body">{{ lbl }}</span>
        </a>
      {%- endfor -%}
    {%- else -%}
      {%- assign default_types = "2x2,3x3,4x4,5x5,Pyraminx,Megaminx,Skewb,Square-1,Clock,Accessories,Lubricants,New Arrivals" | split: "," -%}
      {%- for type in default_types -%}
        {%- assign handle = type | handleize -%}
        {%- assign coll = collections[handle] -%}
        {%- assign auto_img = coll.image | default: coll.products.first.featured_image -%}
        <a href="{{ coll.url | default: '/collections/all' }}" class="cat-tile reveal">
          <div class="cat-tile__img">
            {%- if auto_img != blank -%}
              <img src="{{ auto_img | image_url: width: 500 }}" alt="{{ type | escape }}" loading="lazy">
            {%- else -%}
              <div class="cat-tile__fallback">
                <svg viewBox="0 0 80 80" fill="none" width="48" height="48">
                  <rect x="12" y="12" width="22" height="22" rx="3" fill="rgba(255,208,0,0.25)" stroke="#FFD000" stroke-width="1.5"/>
                  <rect x="34" y="12" width="22" height="22" rx="3" fill="rgba(255,208,0,0.15)" stroke="#FFD000" stroke-width="1.5"/>
                  <rect x="12" y="34" width="22" height="22" rx="3" fill="rgba(26,159,224,0.2)" stroke="#1A9FE0" stroke-width="1.5"/>
                  <rect x="34" y="34" width="22" height="22" rx="3" fill="rgba(26,159,224,0.1)" stroke="#1A9FE0" stroke-width="1.5"/>
                </svg>
              </div>
            {%- endif -%}
          </div>
          <span class="cat-tile__label font-body">{{ type }}</span>
        </a>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

<style>
  .category-grid-section { padding-top: 3rem; padding-bottom: 3.5rem; }
  .cat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.8rem 1.5rem; }
  @media (max-width: 1024px) { .cat-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 768px) { .cat-grid { grid-template-columns: repeat(2, 1fr); gap: 1.2rem 1rem; padding: 0 4px; } }
  @media (max-width: 380px) { .cat-grid { grid-template-columns: repeat(2, 1fr); gap: 0.8rem; } }
  .cat-tile { display: flex; flex-direction: column; align-items: center; text-align: center; text-decoration: none; transition: transform 0.22s ease; gap: 0.75rem; }
  .cat-tile:hover { transform: translateY(-5px); }
  .cat-tile__img { width: 100%; aspect-ratio: 1/1; background: var(--color-surface); border-radius: 14px; border: 1px solid rgba(255,255,255,0.06); box-shadow: 0 4px 14px rgba(0,0,0,0.22); display: flex; align-items: center; justify-content: center; overflow: hidden; transition: box-shadow 0.22s, border-color 0.22s; }
  .cat-tile:hover .cat-tile__img { box-shadow: 0 10px 28px rgba(0,0,0,0.4); border-color: rgba(255,208,0,0.18); }
  .cat-tile__img img { width: 78%; height: 78%; object-fit: contain; transition: transform 0.22s ease; }
  .cat-tile:hover .cat-tile__img img { transform: scale(1.07); }
  .cat-tile__fallback { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: var(--color-surface); }
  .cat-tile__label { font-size: 0.9rem; color: var(--color-text); transition: color 0.2s; font-weight: 500; line-height: 1.3; }
  .cat-tile:hover .cat-tile__label { color: var(--color-primary); }
  @media (max-width: 768px) { .cat-tile__label { font-size: 0.82rem; } }
</style>

{% schema %}
{
  "name": "Category Grid",
  "settings": [],
  "blocks": [
    {
      "type": "category", "name": "Category",
      "settings": [
        { "type": "text", "id": "tile_label", "label": "Category Name" },
        { "type": "image_picker", "id": "tile_image", "label": "Category Image" },
        { "type": "url", "id": "tile_link", "label": "Collection URL" }
      ]
    }
  ],
  "presets": [{
    "name": "Category Grid",
    "blocks": [
      { "type": "category", "settings": { "tile_label": "2x2" } },
      { "type": "category", "settings": { "tile_label": "3x3" } },
      { "type": "category", "settings": { "tile_label": "4x4" } },
      { "type": "category", "settings": { "tile_label": "5x5" } },
      { "type": "category", "settings": { "tile_label": "Pyraminx" } },
      { "type": "category", "settings": { "tile_label": "Megaminx" } },
      { "type": "category", "settings": { "tile_label": "Skewb" } },
      { "type": "category", "settings": { "tile_label": "Square-1" } },
      { "type": "category", "settings": { "tile_label": "Clock" } },
      { "type": "category", "settings": { "tile_label": "Accessories" } },
      { "type": "category", "settings": { "tile_label": "Lubricants" } },
      { "type": "category", "settings": { "tile_label": "New Arrivals" } }
    ]
  }]
}
{% endschema %}
