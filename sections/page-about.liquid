<div class="container section">
  <div class="page-content" style="max-width: 800px; margin: 0 auto; text-align: left;">
    <h1 class="font-display text-center" style="margin-bottom: 2rem; font-size: 3rem;">
      {{ page.title | default: 'About SpeedCubeHub' }}
    </h1>
    
    {%- if page.content != blank -%}
      {{ page.content }}
    {%- else -%}
      <p style="font-size: 1.1rem; color: var(--color-text-muted); margin-bottom: 2rem; text-align: center;">
        Welcome to SpeedCubeHub! We are your premier destination for professional and beginner speedcubes. Our mission is to provide the cubing community with the latest, highest-quality puzzles from top brands around the globe.
      </p>
      
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2rem; margin-top: 3rem;">
        <div style="background: var(--color-surface); padding: 2rem; border-radius: 12px; border: 1px solid var(--color-border); text-align: center;">
          <div style="color: var(--color-primary); font-size: 2rem; margin-bottom: 1rem;">✦</div>
          <h3 class="font-display" style="font-size: 1.2rem; color: white;">Authentic Cubes</h3>
          <p style="font-size: 0.9rem; color: var(--color-text-muted);">Directly sourced from top manufacturers like GAN, MoYu, and QiYi.</p>
        </div>
        <div style="background: var(--color-surface); padding: 2rem; border-radius: 12px; border: 1px solid var(--color-border); text-align: center;">
          <div style="color: var(--color-primary); font-size: 2rem; margin-bottom: 1rem;">🚀</div>
          <h3 class="font-display" style="font-size: 1.2rem; color: white;">Fast Shipping</h3>
          <p style="font-size: 0.9rem; color: var(--color-text-muted);">Worldwide delivery to ensure you get your new main as fast as possible.</p>
        </div>
        <div style="background: var(--color-surface); padding: 2rem; border-radius: 12px; border: 1px solid var(--color-border); text-align: center;">
          <div style="color: var(--color-primary); font-size: 2rem; margin-bottom: 1rem;">🤝</div>
          <h3 class="font-display" style="font-size: 1.2rem; color: white;">Community First</h3>
          <p style="font-size: 0.9rem; color: var(--color-text-muted);">Proud supporters of speedcubing competitions and local clubs.</p>
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "About Page",
  "settings": []
}
{% endschema %}
