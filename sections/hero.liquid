<section class="hero hero-slider" data-section="{{ section.id }}">
  <div class="hero-particles"></div>

  <div class="carousel-container">
    <div class="carousel-track">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- assign prod = block.settings.product -%}
          <div class="carousel-slide {% if forloop.first %}is-active{% endif %}" data-index="{{ forloop.index0 }}">
            <div class="slide-bg-tint bg-tint-{{ forloop.index }}"></div>
            <div class="container hero__content-wrapper">
              <div class="hero__content">
                {%- if prod != blank -%}
                  <p class="hero__highlight font-display color-accent reveal visible" style="transition-delay: 50ms;">
                    {{ block.settings.tagline }}
                  </p>
                  <h1 class="hero__title reveal visible" style="transition-delay: 100ms;">
                    {{ prod.title }}
                  </h1>
                  <div class="hero__buttons reveal visible" style="transition-delay: 200ms;">
                    <a href="{{ prod.url }}" class="btn btn-info">Discover More</a>
                  </div>
                {%- else -%}
                  <p class="hero__highlight font-display color-accent reveal visible" style="transition-delay: 50ms;">
                    {{ block.settings.tagline | default: 'Editor"s Choice' }}
                  </p>
                  <h1 class="hero__title reveal visible" style="transition-delay: 100ms;">
                    {% if forloop.index == 1 %}GAN 14 MagLev
                    {% elsif forloop.index == 2 %}MoYu WeiLong WRM
                    {% else %}YJ MGC 4x4{% endif %}
                  </h1>
                  <div class="hero__buttons reveal visible" style="transition-delay: 200ms;">
                    <a href="#" class="btn btn-info">Discover More</a>
                  </div>
                {%- endif -%}
              </div>
              
              <div class="hero__image-col">
                <div class="hero__image-wrapper tilt-enabled">
                  {%- if prod != blank and prod.featured_image -%}
                    <img src="{{ prod.featured_image | image_url: width: 800 }}" alt="{{ prod.title | escape }}" class="hero-cube-img">
                  {%- else -%}
                    <div class="hero-cube-placeholder">
                      <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" width="200" height="200">
                        <path d="M60 10L10 40V80L60 110L110 80V40L60 10Z" stroke="#FFD000" stroke-width="2" fill="rgba(255,208,0,0.06)"/>
                        <path d="M60 10V110M10 40L110 40M10 80L110 80" stroke="rgba(255,208,0,0.3)" stroke-width="1"/>
                      </svg>
                    </div>
                  {%- endif -%}
                </div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        <!-- Real products fallback from speedcubes collection -->
        {%- assign hero_collection = collections['speedcubes'] -%}
        {%- assign hero_products = hero_collection.products | default: collections['all'].products -%}
        {%- for prod in hero_products limit: 6 -%}
          {%- assign taglines = 'Top Rated,Best Seller,New Arrival,Trending,Fan Favorite,Competition Pick' | split: ',' -%}
          <div class="carousel-slide {% if forloop.first %}is-active{% endif %}" data-index="{{ forloop.index0 }}">
            <div class="slide-bg-tint bg-tint-{{ forloop.index }}"></div>
            <div class="container hero__content-wrapper">
              <div class="hero__content">
                <p class="hero__highlight font-display color-accent reveal visible" style="transition-delay: 50ms;">
                  {{ taglines[forloop.index0] }}
                </p>
                <h1 class="hero__title reveal visible" style="transition-delay: 100ms;">
                  {{ prod.title | truncate: 40 }}
                </h1>
                <p class="hero__subtitle reveal visible" style="transition-delay: 150ms; color: var(--color-text-muted); font-size: 1rem; margin-bottom: 1rem;">
                  {{ prod.vendor }} · {{ prod.product_type }}
                </p>
                <div class="hero__buttons reveal visible" style="transition-delay: 200ms;">
                  <a href="{{ prod.url }}" class="btn btn-primary">
                    Shop Now
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                  </a>
                </div>
                <div class="hero__price-tag reveal visible" style="transition-delay: 250ms; margin-top: 1.5rem;">
                  {%- if prod.compare_at_price > prod.price -%}
                    <span style="color: var(--color-text-muted); text-decoration: line-through; font-size: 0.9rem; margin-right: 0.5rem;">{{ prod.compare_at_price | money }}</span>
                  {%- endif -%}
                  <span style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 900; color: var(--color-primary);">{{ prod.price | money }}</span>
                </div>
              </div>
              <div class="hero__image-col">
                <div class="hero__image-wrapper tilt-enabled">
                  {%- if prod.featured_image -%}
                    {%- assign prod_handle = prod.handle | default: forloop.index -%}
                    <div class="cube-gallery-container" style="position: relative; width: 100%; height: 100%;">
                      <img src="{{ prod.featured_image | image_url: width: 800 }}" alt="{{ prod.title | escape }}" class="hero-cube-img active" loading="eager" id="hero-img-{{ prod_handle }}" data-index="0">
                      
                      {%- if prod.images.size > 1 -%}
                        <div style="display: none;" id="hero-data-{{ prod_handle }}">
                          {%- for img in prod.images -%}
                            <span data-src="{{ img | image_url: width: 800 }}"></span>
                          {%- endfor -%}
                        </div>
                        <button class="mini-gallery-btn prev" aria-label="Previous Image" onclick="changeHeroImage('{{ prod_handle }}', -1, event)" style="position: absolute; top: 50%; left: -30px; transform: translateY(-50%); background: rgba(0,0,0,0.5); border: none; color: white; width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; z-index: 5; transition: background 0.2s;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg></button>
                        <button class="mini-gallery-btn next" aria-label="Next Image" onclick="changeHeroImage('{{ prod_handle }}', 1, event)" style="position: absolute; top: 50%; right: -30px; transform: translateY(-50%); background: rgba(0,0,0,0.5); border: none; color: white; width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; z-index: 5; transition: background 0.2s;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg></button>
                      {%- endif -%}
                    </div>
                  {%- else -%}
                    <div class="hero-cube-placeholder">
                      <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" width="200" height="200">
                        <path d="M60 10L10 40V80L60 110L110 80V40L60 10Z" stroke="#FFD000" stroke-width="2" fill="rgba(255,208,0,0.06)"/>
                        <path d="M60 10V110M10 40L110 40M10 80L110 80" stroke="rgba(255,208,0,0.3)" stroke-width="1"/>
                      </svg>
                    </div>
                  {%- endif -%}
                </div>
              </div>
            </div>
          </div>
        {%- else -%}
          <!-- Last resort: brand name slides if collection is empty -->
          <div class="carousel-slide is-active" data-index="0">
            <div class="slide-bg-tint bg-tint-1"></div>
            <div class="container hero__content-wrapper">
              <div class="hero__content">
                <p class="hero__highlight font-display color-accent reveal visible">Premium Speedcubes</p>
                <h1 class="hero__title reveal visible">The Best Cubes.<br>Delivered Fast.</h1>
                <div class="hero__buttons reveal visible" style="transition-delay: 200ms;">
                  <a href="/collections/speedcubes" class="btn btn-primary">Shop Now</a>
                </div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    <!-- Controls -->
    {%- assign dot_count = section.blocks.size -%}
    {%- if dot_count == 0 -%}{%- assign dot_count = 3 -%}{%- endif -%}
    
    {%- if dot_count > 1 -%}
      <div class="hero-carousel-controls">
        <button class="carousel-btn prev" aria-label="Previous Slide">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <div class="carousel-dots">
          {%- for i in (1..dot_count) -%}
            <button class="carousel-dot {% if forloop.first %}is-active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="Go to slide {{ forloop.index }}"></button>
          {%- endfor -%}
        </div>
        <button class="carousel-btn next" aria-label="Next Slide">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .hero-slider {
    position: relative;
    min-height: calc(100vh - 80px);
    height: auto;
    background-color: var(--color-bg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .carousel-container {
    width: 100%;
    flex: 1;
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    padding-bottom: 50px;
  }

  .carousel-track {
    display: flex;
    flex: 1;
    transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1);
    width: 100%;
  }

  .carousel-slide {
    min-width: 100%;
    opacity: 0.3;
    transition: opacity 0.5s ease;
    display: flex;
    align-items: center;
    position: relative;
  }

  .slide-bg-tint {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    z-index: 0;
    pointer-events: none;
  }
  .bg-tint-1 { background: radial-gradient(ellipse at center, rgba(26,159,224,0.1) 0%, transparent 60%); }
  .bg-tint-2 { background: radial-gradient(ellipse at center, rgba(255,208,0,0.1) 0%, transparent 60%); }
  .bg-tint-3 { background: radial-gradient(ellipse at center, rgba(255,107,26,0.1) 0%, transparent 60%); }

  .carousel-slide.is-active {
    opacity: 1;
  }

  .hero__content-wrapper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    gap: 4rem;
  }

  .hero__content {
    flex: 1;
    max-width: 500px;
  }

  .hero__highlight {
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 1rem;
    font-weight: 700;
  }

  .hero__title {
    font-size: clamp(3rem, 5vw, 4.5rem);
    line-height: 1.1;
    text-transform: uppercase;
    margin-bottom: 2rem;
    text-shadow: 0 10px 30px rgba(0,0,0,0.5);
  }

  .hero__image-col {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    perspective: 1000px;
  }

  .hero__image-wrapper {
    width: 100%;
    max-width: 500px;
    aspect-ratio: 1/1;
    position: relative;
    filter: drop-shadow(0 20px 40px rgba(0,0,0,0.4));
    transition: transform 0.1s ease-out, filter 0.3s ease;
  }

  .hero__image-wrapper:hover {
    filter: drop-shadow(0 30px 60px var(--color-glow));
  }

  .hero-cube-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .placeholder-svg {
    background: var(--color-surface);
    border-radius: var(--border-radius);
    padding: 2rem;
    fill: var(--color-text-muted);
  }

  /* Positioned INSIDE the hero section, absolutely at the bottom */
  .hero-carousel-controls {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .carousel-btn {
    width: 44px; height: 44px; border-radius: 50%;
    background: rgba(255,208,0,0.1);
    border: 1px solid rgba(255,208,0,0.3);
    color: #FFD000; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.2s;
  }

  .carousel-btn:hover {
    background: rgba(255,208,0,0.22);
  }

  .carousel-dots {
    display: flex;
    gap: 8px;
  }

  .carousel-dot {
    width: 8px; height: 8px; border-radius: 4px;
    background: rgba(255,255,255,0.25);
    border: none;
    cursor: pointer;
    transition: all 0.3s;
  }

  .carousel-dot.is-active {
    width: 20px; background: #FFD000; transform: none;
  }

  @media (max-width: 768px) {
    .hero__content-wrapper {
      flex-direction: column-reverse;
      text-align: center;
      gap: 2rem;
      padding-top: 2rem;
    }
    .hero__title {
      font-size: 2.5rem;
    }
    .hero__image-wrapper {
      max-width: 300px;
    }
    .hero__buttons {
      justify-content: center;
    }
  }
</style>

<script>
  function changeHeroImage(handle, dir, e) {
    if (e) { e.preventDefault(); e.stopPropagation(); }
    const imgEl = document.getElementById('hero-img-' + handle);
    const dataContainer = document.getElementById('hero-data-' + handle);
    if (!imgEl || !dataContainer) return;
    
    const spans = dataContainer.querySelectorAll('span');
    if (spans.length === 0) return;
    
    let currentIndex = parseInt(imgEl.getAttribute('data-index') || '0', 10);
    currentIndex += dir;
    if (currentIndex < 0) currentIndex = spans.length - 1;
    if (currentIndex >= spans.length) currentIndex = 0;
    
    const newSrc = spans[currentIndex].getAttribute('data-src');
    imgEl.src = newSrc;
    imgEl.setAttribute('data-index', currentIndex);
  }

  document.addEventListener('DOMContentLoaded', () => {
    const track = document.querySelector('.carousel-track');
    const slides = document.querySelectorAll('.carousel-slide');
    const prevBtn = document.querySelector('.carousel-btn.prev');
    const nextBtn = document.querySelector('.carousel-btn.next');
    const dots = document.querySelectorAll('.carousel-dot');
    
    if(!track || slides.length === 0) return;

    let currentIndex = 0;
    let autoSlideInterval;

    function goToSlide(index) {
      if(index < 0) index = slides.length - 1;
      if(index >= slides.length) index = 0;
      
      currentIndex = index;
      const offset = currentIndex * -100;
      track.style.transform = `translateX(${offset}%)`;
      
      slides.forEach(s => s.classList.remove('is-active'));
      slides[currentIndex].classList.add('is-active');
      
      dots.forEach(d => d.classList.remove('is-active'));
      if(dots[currentIndex]) dots[currentIndex].classList.add('is-active');
    }

    if(nextBtn) {
      nextBtn.addEventListener('click', () => {
        goToSlide(currentIndex + 1);
        resetInterval();
      });
    }

    if(prevBtn) {
      prevBtn.addEventListener('click', () => {
        goToSlide(currentIndex - 1);
        resetInterval();
      });
    }

    dots.forEach((dot, idx) => {
      dot.addEventListener('click', () => {
        goToSlide(idx);
        resetInterval();
      });
    });

    function startInterval() {
      autoSlideInterval = setInterval(() => {
        goToSlide(currentIndex + 1);
      }, 5000); // 5 seconds per slide
    }

    function resetInterval() {
      clearInterval(autoSlideInterval);
      startInterval();
    }

    // Touch swipe support
    let touchStartX = 0;
    let touchEndX = 0;

    track.addEventListener('touchstart', e => {
      touchStartX = e.changedTouches[0].screenX;
      clearInterval(autoSlideInterval);
    });

    track.addEventListener('touchend', e => {
      touchEndX = e.changedTouches[0].screenX;
      handleSwipe();
      startInterval();
    });

    function handleSwipe() {
      if(touchEndX < touchStartX - 50) goToSlide(currentIndex + 1);
      if(touchEndX > touchStartX + 50) goToSlide(currentIndex - 1);
    }

    startInterval();
  });
</script>

{% schema %}
{
  "name": "Hero Slider",
  "max_blocks": 3,
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Product Slide",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        },
        {
          "type": "text",
          "id": "tagline",
          "label": "Tagline",
          "default": "The New Meta"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Slider",
      "blocks": [
        { "type": "slide", "settings": { "tagline": "The New Meta" } },
        { "type": "slide", "settings": { "tagline": "Budget King" } },
        { "type": "slide", "settings": { "tagline": "Top Choice" } }
      ]
    }
  ]
}
{% endschema %}
