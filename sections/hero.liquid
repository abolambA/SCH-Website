{% comment %} Hero Banner Carousel — full-image banners, no text overlay {% endcomment %}

<section class="hero-banner-section" id="hero-banner-{{ section.id }}" data-section="{{ section.id }}">
  <div class="hb-track-wrapper">
    <div class="hb-track" id="hbTrack-{{ section.id }}">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- assign slide_link = block.settings.link | default: routes.all_products_collection_url -%}
          <div class="hb-slide {% if forloop.first %}hb-slide--active{% endif %}" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
            <a href="{{ slide_link }}" class="hb-slide__link" aria-label="{{ block.settings.alt | default: 'View' }}">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 1920 }}"
                  srcset="{{ block.settings.image | image_url: width: 750 }} 750w, {{ block.settings.image | image_url: width: 1200 }} 1200w, {{ block.settings.image | image_url: width: 1920 }} 1920w"
                  sizes="100vw"
                  alt="{{ block.settings.alt | default: shop.name | escape }}"
                  class="hb-slide__img"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  width="1920" height="650">
              {%- elsif block.settings.product != blank -%}
                {%- assign bprod = block.settings.product -%}
                {%- if bprod.featured_image -%}
                  <img src="{{ bprod.featured_image | image_url: width: 1920 }}" alt="{{ bprod.title | escape }}" class="hb-slide__img hb-slide__img--contain" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}" width="1920" height="650">
                {%- else -%}
                  <div class="hb-slide__placeholder"></div>
                {%- endif -%}
              {%- else -%}
                <div class="hb-slide__placeholder"></div>
              {%- endif -%}
            </a>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for prod in collections['all'].products limit: 4 -%}
          <div class="hb-slide {% if forloop.first %}hb-slide--active{% endif %}" data-index="{{ forloop.index0 }}">
            <a href="{{ prod.url }}" class="hb-slide__link">
              {%- if prod.featured_image -%}
                <img src="{{ prod.featured_image | image_url: width: 1920 }}" alt="{{ prod.title | escape }}" class="hb-slide__img hb-slide__img--contain" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}" width="1920" height="500">
              {%- else -%}
                <div class="hb-slide__placeholder"></div>
              {%- endif -%}
            </a>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- assign slide_count = section.blocks.size | default: 4 -%}
    {%- if slide_count > 1 -%}
      <button class="hb-btn hb-btn--prev" id="hbPrev-{{ section.id }}" aria-label="Previous slide">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>
      <button class="hb-btn hb-btn--next" id="hbNext-{{ section.id }}" aria-label="Next slide">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
      <div class="hb-dots" id="hbDots-{{ section.id }}">
        {%- for i in (1..slide_count) -%}
          <button class="hb-dot {% if forloop.first %}hb-dot--active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="Slide {{ forloop.index }}"></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
.hero-banner-section { position:relative; width:100%; background:#071726; overflow:hidden; line-height:0; }
.hb-track-wrapper { position:relative; width:100%; overflow:hidden; }
.hb-track { display:flex; transition:transform 0.6s cubic-bezier(0.25,1,0.5,1); will-change:transform; }
.hb-slide { min-width:100%; position:relative; flex-shrink:0; }
.hb-slide__link { display:block; width:100%; line-height:0; }
.hb-slide__img { width:100%; height:auto; max-height:650px; object-fit:cover; display:block; }
.hb-slide__img--contain { object-fit:contain; background:linear-gradient(135deg,#071726 0%,#0d2035 100%); min-height:300px; }
.hb-slide__placeholder { width:100%; height:400px; background:linear-gradient(135deg,#071726 0%,#0d2035 100%); }
/* Nav buttons */
.hb-btn { position:absolute; top:50%; transform:translateY(-50%); z-index:10; width:46px; height:46px; border-radius:50%; background:rgba(255,255,255,0.15); border:1.5px solid rgba(255,255,255,0.3); color:#fff; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:all 0.2s; backdrop-filter:blur(8px); -webkit-backdrop-filter:blur(8px); padding:0; }
.hb-btn:hover { background:#FFD000; border-color:#FFD000; color:#071726; }
.hb-btn--prev { left:16px; }
.hb-btn--next { right:16px; }
/* Dots — fixed size, no overflow */
.hb-dots { position:absolute; bottom:14px; left:50%; transform:translateX(-50%); display:flex; gap:6px; align-items:center; z-index:10; padding:5px 10px; background:rgba(0,0,0,0.3); border-radius:20px; backdrop-filter:blur(4px); -webkit-backdrop-filter:blur(4px); }
.hb-dot { width:8px; height:8px; min-width:8px; max-width:8px; min-height:8px; max-height:8px; border-radius:50%; background:rgba(255,255,255,0.45); border:none; cursor:pointer; padding:0; flex-shrink:0; transition:all 0.3s; box-sizing:border-box; font-size:0; line-height:0; display:inline-block; vertical-align:middle; }
.hb-dot--active { background:#FFD000 !important; width:22px !important; min-width:22px !important; max-width:22px !important; border-radius:4px !important; }
/* Responsive */
@media(max-width:768px) {
  .hb-slide__img { max-height:260px; min-height:160px; }
  .hb-slide__img--contain { min-height:160px; }
  .hb-btn { width:36px; height:36px; }
  .hb-btn--prev { left:8px; }
  .hb-btn--next { right:8px; }
  .hb-dots { bottom:8px; padding:4px 8px; gap:5px; }
  .hb-dot { width:6px !important; height:6px !important; min-width:6px !important; max-width:6px !important; min-height:6px !important; max-height:6px !important; }
  .hb-dot--active { width:16px !important; min-width:16px !important; max-width:16px !important; }
}
@media(max-width:480px) {
  .hb-slide__img { max-height:200px; min-height:130px; }
  .hb-btn { display:none !important; }
  .hb-dots { bottom:6px; }
}
</style>

<script>
(function(){
  function initHeroBanner(sid){
    var wrap=document.getElementById('hero-banner-'+sid);
    if(!wrap)return;
    var track=document.getElementById('hbTrack-'+sid);
    if(!track)return;
    var slides=Array.from(track.querySelectorAll('.hb-slide'));
    var prevBtn=document.getElementById('hbPrev-'+sid);
    var nextBtn=document.getElementById('hbNext-'+sid);
    var dotsC=document.getElementById('hbDots-'+sid);
    var dots=dotsC?Array.from(dotsC.querySelectorAll('.hb-dot')):[];
    if(slides.length<=1)return;
    var cur=0,autoTimer;
    function goTo(n){
      if(n<0)n=slides.length-1;
      if(n>=slides.length)n=0;
      cur=n;
      track.style.transform='translateX('+(cur*-100)+'%)';
      slides.forEach(function(s,i){s.classList.toggle('hb-slide--active',i===cur);});
      dots.forEach(function(d,i){d.classList.toggle('hb-dot--active',i===cur);});
    }
    function startAuto(){autoTimer=setInterval(function(){goTo(cur+1);},5000);}
    function stopAuto(){clearInterval(autoTimer);}
    function resetAuto(){stopAuto();startAuto();}
    if(prevBtn)prevBtn.addEventListener('click',function(){goTo(cur-1);resetAuto();});
    if(nextBtn)nextBtn.addEventListener('click',function(){goTo(cur+1);resetAuto();});
    dots.forEach(function(d,i){d.addEventListener('click',function(){goTo(i);resetAuto();});});
    var tStart=0;
    track.addEventListener('touchstart',function(e){tStart=e.changedTouches[0].screenX;stopAuto();},{passive:true});
    track.addEventListener('touchend',function(e){
      var diff=e.changedTouches[0].screenX-tStart;
      if(Math.abs(diff)>40)goTo(cur+(diff<0?1:-1));
      startAuto();
    },{passive:true});
    startAuto();
  }
  var sid='{{ section.id }}';
  if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',function(){initHeroBanner(sid);});}
  else{initHeroBanner(sid);}
})();
</script>

{% schema %}
{
  "name": "Hero Banner Slider",
  "max_blocks": 8,
  "settings": [],
  "blocks": [
    {
      "type": "banner",
      "name": "Banner Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Banner Image", "info": "Recommended: 1920x650px. Full-width, no text overlay." },
        { "type": "url", "id": "link", "label": "Banner Link (where it goes when clicked)" },
        { "type": "text", "id": "alt", "label": "Alt text", "default": "Shop now" },
        { "type": "product", "id": "product", "label": "Or: use product image as banner (fallback if no image above)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner Slider",
      "blocks": [
        { "type": "banner", "settings": { "link": "/collections/all", "alt": "Shop New Arrivals" } },
        { "type": "banner", "settings": { "link": "/collections/gan", "alt": "GAN Cubes" } },
        { "type": "banner", "settings": { "link": "/collections/moyu", "alt": "MoYu Cubes" } }
      ]
    }
  ]
}
{% endschema %}
