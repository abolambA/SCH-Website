{% comment %} Hero Carousel — product image + name, more product title space on mobile {% endcomment %}

<section class="hero-section" id="hero-{{ section.id }}" data-section="{{ section.id }}">
  <div class="hero-carousel" id="heroCarousel-{{ section.id }}">

    {%- if section.blocks.size > 0 -%}
      {%- for block in section.blocks -%}
        {%- assign slide_product = block.settings.product -%}
        {%- assign slide_link = block.settings.link | default: slide_product.url | default: routes.all_products_collection_url -%}

        <div class="hero-slide {% if forloop.first %}is-active{% endif %}" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
          <div class="hero-slide__inner">

            <!-- Left: Text -->
            <div class="hero-slide-left">
              {%- if block.settings.eyebrow != blank -%}
                <p class="hero-eyebrow font-display">{{ block.settings.eyebrow }}</p>
              {%- elsif slide_product != blank -%}
                <p class="hero-eyebrow font-display">{{ slide_product.vendor | default: 'SpeedCubeHub' }}</p>
              {%- else -%}
                <p class="hero-eyebrow font-display">SpeedCubeHub</p>
              {%- endif -%}

              <h2 class="hero-slide__title font-display">
                {%- if block.settings.heading != blank -%}
                  {{ block.settings.heading }}
                {%- elsif slide_product != blank -%}
                  {{ slide_product.title }}
                {%- else -%}
                  Shop The Best Speedcubes
                {%- endif -%}
              </h2>

              {%- if block.settings.subtext != blank -%}
                <p class="hero-slide__sub">{{ block.settings.subtext }}</p>
              {%- elsif slide_product != blank and slide_product.description != blank -%}
                <p class="hero-slide__sub">{{ slide_product.description | strip_html | truncate: 120 }}</p>
              {%- endif -%}

              {%- if slide_product != blank -%}
                <div class="hero-slide__price-row">
                  {%- if slide_product.compare_at_price > slide_product.price -%}
                    <span class="hero-price-sale font-display">{{ slide_product.price | money }}</span>
                    <span class="hero-price-old">{{ slide_product.compare_at_price | money }}</span>
                    <span class="hero-badge-sale font-display">SALE</span>
                  {%- else -%}
                    <span class="hero-price font-display">{{ slide_product.price | money }}</span>
                  {%- endif -%}
                </div>
              {%- endif -%}

              <a href="{{ slide_link }}" class="btn btn-primary hero-cta">
                {%- if block.settings.cta_text != blank -%}{{ block.settings.cta_text }}{%- elsif slide_product != blank -%}Shop Now{%- else -%}View All Cubes{%- endif -%}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </a>
            </div>

            <!-- Right: Image -->
            <div class="hero-slide-right">
              <div class="hero-img-frame">
                {%- if block.settings.image != blank -%}
                  <img src="{{ block.settings.image | image_url: width: 900 }}"
                       alt="{{ block.settings.heading | default: shop.name | escape }}"
                       class="hero-img"
                       loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                       width="640" height="640">
                {%- elsif slide_product != blank and slide_product.featured_image != blank -%}
                  <img src="{{ slide_product.featured_image | image_url: width: 900 }}"
                       alt="{{ slide_product.title | escape }}"
                       class="hero-img"
                       loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                       width="640" height="640">
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'hero-img' }}
                {%- endif -%}
                <div class="hero-img-glow" aria-hidden="true"></div>
              </div>
            </div>

          </div>
        </div>
      {%- endfor -%}

    {%- else -%}
      <!-- Fallback: pull from all products -->
      {%- for prod in collections['all'].products limit: 4 -%}
        <div class="hero-slide {% if forloop.first %}is-active{% endif %}" data-index="{{ forloop.index0 }}">
          <div class="hero-slide__inner">
            <div class="hero-slide-left">
              <p class="hero-eyebrow font-display">{{ prod.vendor }}</p>
              <h2 class="hero-slide__title font-display">{{ prod.title }}</h2>
              <div class="hero-slide__price-row">
                {%- if prod.compare_at_price > prod.price -%}
                  <span class="hero-price-sale font-display">{{ prod.price | money }}</span>
                  <span class="hero-price-old">{{ prod.compare_at_price | money }}</span>
                  <span class="hero-badge-sale font-display">SALE</span>
                {%- else -%}
                  <span class="hero-price font-display">{{ prod.price | money }}</span>
                {%- endif -%}
              </div>
              <a href="{{ prod.url }}" class="btn btn-primary hero-cta">
                Shop Now
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </a>
            </div>
            <div class="hero-slide-right">
              <div class="hero-img-frame">
                {%- if prod.featured_image -%}
                  <img src="{{ prod.featured_image | image_url: width: 900 }}" alt="{{ prod.title | escape }}" class="hero-img" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}" width="640" height="640">
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'hero-img' }}
                {%- endif -%}
                <div class="hero-img-glow" aria-hidden="true"></div>
              </div>
            </div>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}

  </div>

  {%- assign total_slides = section.blocks.size | default: 4 -%}
  {%- if total_slides > 1 -%}
    <!-- Arrows -->
    <button class="hc-btn hc-btn--prev" id="hcPrev-{{ section.id }}" aria-label="Previous">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
    </button>
    <button class="hc-btn hc-btn--next" id="hcNext-{{ section.id }}" aria-label="Next">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </button>
    <!-- Dots -->
    <div class="hc-dots" id="hcDots-{{ section.id }}">
      {%- for i in (1..total_slides) -%}
        <button class="hc-dot {% if forloop.first %}hc-dot--active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="Slide {{ forloop.index }}"></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

<style>
/* ===== HERO SECTION ===== */
.hero-section {
  position: relative;
  background: linear-gradient(135deg, #060f1e 0%, #0d1f35 50%, #071726 100%);
  overflow: hidden;
  min-height: 460px;
  display: flex;
  align-items: center;
}

.hero-carousel { width: 100%; position: relative; }

.hero-slide {
  display: none;
  padding: 3rem 0;
}
.hero-slide.is-active { display: block; }

.hero-slide__inner {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 2rem;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: center;
}

/* Left text col */
.hero-slide-left { display: flex; flex-direction: column; gap: 1rem; }
.hero-eyebrow {
  font-size: 0.78rem;
  letter-spacing: 3px;
  text-transform: uppercase;
  font-weight: 700;
  color: var(--color-primary);
  margin: 0;
}
.hero-slide__title {
  font-size: clamp(1.6rem, 3.5vw, 3.2rem);
  text-transform: uppercase;
  line-height: 1.1;
  margin: 0;
  color: #fff;
  letter-spacing: 0.02em;
}
.hero-slide__sub {
  color: rgba(255,255,255,0.65);
  font-size: clamp(0.88rem, 1.2vw, 1rem);
  line-height: 1.7;
  margin: 0;
  max-width: 480px;
}
.hero-slide__price-row {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-wrap: wrap;
}
.hero-price, .hero-price-sale {
  font-size: 1.6rem;
  font-weight: 900;
  color: var(--color-primary);
}
.hero-price-old {
  font-size: 1rem;
  color: rgba(255,255,255,0.4);
  text-decoration: line-through;
}
.hero-badge-sale {
  background: #ef4444;
  color: #fff;
  font-size: 0.72rem;
  font-weight: 800;
  padding: 3px 10px;
  border-radius: 5px;
  letter-spacing: 1px;
}
.hero-cta {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  align-self: flex-start;
  margin-top: 0.5rem;
}

/* Right image col */
.hero-slide-right { display: flex; align-items: center; justify-content: center; }
.hero-img-frame {
  position: relative;
  width: 100%;
  max-width: 420px;
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24px;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,208,0,0.1);
  overflow: hidden;
}
.hero-img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  padding: 1.5rem;
  display: block;
}
.hero-img-glow {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 50% 50%, rgba(255,208,0,0.08) 0%, transparent 70%);
  pointer-events: none;
}

/* Nav buttons */
.hc-btn {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
  width: 44px; height: 44px;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  border: 1.5px solid rgba(255,255,255,0.2);
  color: #fff;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.2s;
  backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
  padding: 0;
}
.hc-btn:hover { background: #FFD000; border-color: #FFD000; color: #071726; }
.hc-btn--prev { left: 16px; }
.hc-btn--next { right: 16px; }

/* Dots */
.hc-dots {
  position: absolute;
  bottom: 14px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 6px;
  align-items: center;
  z-index: 10;
  padding: 5px 10px;
  background: rgba(0,0,0,0.3);
  border-radius: 20px;
  backdrop-filter: blur(4px);
}
.hc-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: rgba(255,255,255,0.4);
  border: none;
  cursor: pointer;
  padding: 0;
  transition: all 0.3s;
  flex-shrink: 0;
}
.hc-dot--active {
  background: #FFD000 !important;
  width: 22px !important;
  border-radius: 4px !important;
}

/* ===== MOBILE ===== */
@media (max-width: 900px) {
  .hero-section { min-height: unset; }
  .hero-slide { padding: 2rem 0 3rem; }
  .hero-slide__inner {
    grid-template-columns: 1fr;
    gap: 1.5rem;
    padding: 0 1.2rem;
    text-align: center;
  }
  .hero-slide-right { order: -1; }
  .hero-img-frame { max-width: 260px; margin: 0 auto; }
  .hero-cta { align-self: center; }
  .hero-slide__sub { margin: 0 auto; }
  .hero-slide__price-row { justify-content: center; }
  .hc-btn { display: none !important; }
}

@media (max-width: 480px) {
  .hero-slide { padding: 1.5rem 0 3rem; }
  .hero-slide__inner { padding: 0 1rem; gap: 1rem; }
  /* More space for the product title on small phones */
  .hero-slide__title {
    font-size: clamp(1.3rem, 5.5vw, 1.8rem);
    line-height: 1.15;
    letter-spacing: 0;
    word-break: break-word;
  }
  .hero-img-frame { max-width: 200px; }
  .hero-eyebrow { font-size: 0.7rem; letter-spacing: 2px; }
  .hero-slide__sub { font-size: 0.82rem; }
  .hero-price, .hero-price-sale { font-size: 1.3rem; }
  .hc-dots { bottom: 6px; padding: 4px 8px; }
  .hc-dot { width: 6px !important; height: 6px !important; }
  .hc-dot--active { width: 14px !important; }
}
</style>

<script>
(function(){
  function initHeroCarousel(sid) {
    var section = document.getElementById('hero-' + sid);
    if (!section) return;
    var slides = Array.from(section.querySelectorAll('.hero-slide'));
    if (slides.length <= 1) return;

    var prevBtn = document.getElementById('hcPrev-' + sid);
    var nextBtn = document.getElementById('hcNext-' + sid);
    var dotsC = document.getElementById('hcDots-' + sid);
    var dots = dotsC ? Array.from(dotsC.querySelectorAll('.hc-dot')) : [];
    var cur = 0, autoTimer;

    function goTo(n) {
      if (n < 0) n = slides.length - 1;
      if (n >= slides.length) n = 0;
      slides[cur].classList.remove('is-active');
      if (dots[cur]) dots[cur].classList.remove('hc-dot--active');
      cur = n;
      slides[cur].classList.add('is-active');
      if (dots[cur]) dots[cur].classList.add('hc-dot--active');
    }
    function startAuto() { autoTimer = setInterval(function(){ goTo(cur + 1); }, 5000); }
    function resetAuto() { clearInterval(autoTimer); startAuto(); }

    if (prevBtn) prevBtn.addEventListener('click', function(){ goTo(cur - 1); resetAuto(); });
    if (nextBtn) nextBtn.addEventListener('click', function(){ goTo(cur + 1); resetAuto(); });
    dots.forEach(function(d, i){ d.addEventListener('click', function(){ goTo(i); resetAuto(); }); });

    var ts = 0;
    section.addEventListener('touchstart', function(e){ ts = e.changedTouches[0].screenX; }, {passive:true});
    section.addEventListener('touchend', function(e){
      var diff = e.changedTouches[0].screenX - ts;
      if (Math.abs(diff) > 40) { goTo(cur + (diff < 0 ? 1 : -1)); resetAuto(); }
    }, {passive:true});

    startAuto();
  }

  var sid = '{{ section.id }}';
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function(){ initHeroCarousel(sid); });
  } else {
    initHeroCarousel(sid);
  }
})();
</script>

{% schema %}
{
  "name": "Hero Carousel",
  "max_blocks": 8,
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Hero Slide",
      "settings": [
        { "type": "product", "id": "product", "label": "Product (auto-fills title, image, price)" },
        { "type": "image_picker", "id": "image", "label": "Override Image (optional)" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow text (e.g. brand name)", "placeholder": "GAN Cube" },
        { "type": "text", "id": "heading", "label": "Override heading", "placeholder": "Leave blank to use product title" },
        { "type": "text", "id": "subtext", "label": "Subtext", "placeholder": "Short description" },
        { "type": "text", "id": "cta_text", "label": "Button text", "default": "Shop Now" },
        { "type": "url", "id": "link", "label": "Button link (leave blank to use product URL)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Carousel",
      "blocks": [
        { "type": "slide", "settings": { "eyebrow": "GAN Cube", "heading": "Shop The Best Speedcubes", "cta_text": "Shop Now", "link": "/collections/all" } },
        { "type": "slide", "settings": { "eyebrow": "New Arrivals", "heading": "Fastest Cubes In The Region", "cta_text": "View All", "link": "/collections/all" } }
      ]
    }
  ]
}
{% endschema %}
