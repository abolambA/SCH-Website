<section class="hero hero-slider" data-section="{{ section.id }}">
  <div class="hero-bg-overlay"></div>
  <div class="carousel-container">
    <div class="carousel-track">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- assign prod = block.settings.product -%}
          <div class="carousel-slide {% if forloop.first %}is-active{% endif %}" data-index="{{ forloop.index0 }}">
            <div class="container hero__content-wrapper">
              <div class="hero__content">
                <p class="hero__highlight font-display color-accent">{{ block.settings.tagline | default: 'Featured' }}</p>
                <h1 class="hero__title">{%- if prod != blank -%}{{ prod.title }}{%- else -%}SpeedCubeHub{%- endif -%}</h1>
                {%- if prod != blank -%}
                  <p class="hero__vendor" style="color:var(--color-text-muted);font-size:0.9rem;margin-bottom:0.8rem;">{{ prod.vendor }}</p>
                  <div class="hero__price-tag">
                    {%- if prod.compare_at_price > prod.price -%}
                      <span class="hero__compare-price">{{ prod.compare_at_price | money }}</span>
                    {%- endif -%}
                    <span class="hero__price font-display">{{ prod.price | money }}</span>
                  </div>
                {%- endif -%}
                <div class="hero__buttons">
                  <a href="{{ prod.url | default: routes.all_products_collection_url }}" class="btn btn-primary">
                    Shop Now
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                  </a>
                </div>
              </div>
              <div class="hero__image-col">
                <div class="hero__image-wrapper">
                  {%- if prod != blank and prod.featured_image -%}
                    <img src="{{ prod.featured_image | image_url: width: 500 }}" alt="{{ prod.title | escape }}" class="hero-cube-img" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
                  {%- else -%}
                    <div class="hero-cube-placeholder">
                      <svg viewBox="0 0 120 120" fill="none" width="160" height="160"><path d="M60 10L10 40V80L60 110L110 80V40L60 10Z" stroke="#FFD000" stroke-width="2" fill="rgba(255,208,0,0.06)"/><path d="M60 10V110M10 40L110 40M10 80L110 80" stroke="rgba(255,208,0,0.3)" stroke-width="1"/></svg>
                    </div>
                  {%- endif -%}
                </div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- assign taglines = 'Top Rated,Best Seller,New Arrival' | split: ',' -%}
        {%- for prod in collections['all'].products limit: 3 -%}
          <div class="carousel-slide {% if forloop.first %}is-active{% endif %}" data-index="{{ forloop.index0 }}">
            <div class="container hero__content-wrapper">
              <div class="hero__content">
                <p class="hero__highlight font-display color-accent">{{ taglines[forloop.index0] }}</p>
                <h1 class="hero__title">{{ prod.title | truncate: 40 }}</h1>
                <p class="hero__vendor" style="color:var(--color-text-muted);font-size:0.9rem;margin-bottom:0.8rem;">{{ prod.vendor }}</p>
                <div class="hero__price-tag">
                  {%- if prod.compare_at_price > prod.price -%}
                    <span class="hero__compare-price">{{ prod.compare_at_price | money }}</span>
                  {%- endif -%}
                  <span class="hero__price font-display">{{ prod.price | money }}</span>
                </div>
                <div class="hero__buttons">
                  <a href="{{ prod.url }}" class="btn btn-primary">Shop Now <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg></a>
                </div>
              </div>
              <div class="hero__image-col">
                <div class="hero__image-wrapper">
                  {%- if prod.featured_image -%}
                    <img src="{{ prod.featured_image | image_url: width: 500 }}" alt="{{ prod.title | escape }}" class="hero-cube-img" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
                  {%- else -%}
                    <div class="hero-cube-placeholder"><svg viewBox="0 0 120 120" fill="none" width="160" height="160"><path d="M60 10L10 40V80L60 110L110 80V40L60 10Z" stroke="#FFD000" stroke-width="2" fill="rgba(255,208,0,0.06)"/></svg></div>
                  {%- endif -%}
                </div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- assign dot_count = section.blocks.size | default: 3 -%}
    {%- if dot_count > 1 -%}
      <div class="hero-carousel-controls">
        <button class="carousel-btn hero-prev" aria-label="Previous">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <div class="carousel-dots">
          {%- for i in (1..dot_count) -%}
            <button class="carousel-dot {% if forloop.first %}is-active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="Slide {{ forloop.index }}"></button>
          {%- endfor -%}
        </div>
        <button class="carousel-btn hero-next" aria-label="Next">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .hero-slider {
    position: relative;
    height: 460px;
    overflow: hidden;
    background: #071726;
  }
  .hero-bg-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(6,15,26,0.9) 0%, rgba(6,15,26,0.5) 60%, rgba(6,15,26,0.1) 100%);
    z-index: 2; pointer-events: none;
  }
  .carousel-container {
    width: 100%; height: 100%; position: relative; z-index: 3;
    display: flex; flex-direction: column;
  }
  .carousel-track {
    display: flex; flex: 1;
    transition: transform 0.55s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .carousel-slide {
    min-width: 100%; display: flex; align-items: center;
  }
  .hero__content-wrapper {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; gap: 2rem;
    padding-bottom: 3rem; /* room for controls */
  }
  .hero__content { flex: 1; max-width: 500px; }
  .hero__highlight { font-size: 0.82rem; text-transform: uppercase; letter-spacing: 3px; margin-bottom: 0.6rem; font-weight: 700; }
  .hero__title {
    font-family: var(--font-display); font-weight: 900;
    font-size: clamp(1.8rem, 3.5vw, 3rem); line-height: 1.05;
    text-transform: uppercase; margin-bottom: 0.6rem;
  }
  .hero__price-tag { display: flex; align-items: baseline; gap: 0.8rem; margin-bottom: 1.4rem; }
  .hero__price { font-size: 1.5rem; font-weight: 900; color: var(--color-primary); }
  .hero__compare-price { font-size: 0.95rem; color: var(--color-text-muted); text-decoration: line-through; }
  .hero__buttons { display: flex; gap: 0.8rem; flex-wrap: wrap; }

  /* Image — smaller than before */
  .hero__image-col {
    flex: 0 0 auto; width: 280px;
    display: flex; justify-content: center; align-items: center;
  }
  .hero__image-wrapper {
    width: 260px; height: 260px;
    filter: drop-shadow(0 12px 28px rgba(0,0,0,0.5));
    transition: filter 0.3s;
  }
  .hero__image-wrapper:hover { filter: drop-shadow(0 20px 40px rgba(255,208,0,0.2)); }
  .hero-cube-img { width: 100%; height: 100%; object-fit: contain; }
  .hero-cube-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; }

  /* Controls — overlaid at bottom center */
  .hero-carousel-controls {
    position: absolute; bottom: 14px; left: 50%; transform: translateX(-50%);
    z-index: 10; display: flex; align-items: center; gap: 10px;
  }
  .carousel-btn {
    width: 34px; height: 34px;
    background: rgba(255,255,255,0.1); border: 1.5px solid rgba(255,255,255,0.2);
    border-radius: 50%; color: rgba(255,255,255,0.9);
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: all 0.2s; backdrop-filter: blur(8px); padding: 0;
  }
  .carousel-btn:hover { background: #FFD000; border-color: #FFD000; color: #071726; }
  .carousel-dots { display: flex; gap: 6px; align-items: center; }
  .carousel-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: rgba(255,255,255,0.3); border: none; cursor: pointer;
    transition: all 0.3s; padding: 0;
  }
  .carousel-dot.is-active { background: #FFD000; width: 20px; border-radius: 4px; }

  /* Responsive */
  @media (max-width: 900px) {
    .hero-slider { height: auto; min-height: 400px; }
    .hero__content-wrapper { flex-direction: column-reverse; text-align: center; gap: 1rem; padding: 1.5rem 0 3.5rem; }
    .hero__image-col { width: 100%; }
    .hero__image-wrapper { width: 180px; height: 180px; }
    .hero__buttons { justify-content: center; }
  }
  @media (max-width: 480px) {
    .hero-slider { min-height: 360px; }
    .hero__title { font-size: 1.6rem; }
    .hero__image-wrapper { width: 150px; height: 150px; }
  }
</style>

<script>
  (function() {
    function initHeroSlider() {
      var section = document.querySelector('.hero-slider');
      if (!section) return;
      var track = section.querySelector('.carousel-track');
      var slides = section.querySelectorAll('.carousel-slide');
      var prevBtn = section.querySelector('.hero-prev');
      var nextBtn = section.querySelector('.hero-next');
      var dots = section.querySelectorAll('.carousel-dot');
      if (!track || slides.length === 0) return;
      var cur = 0, timer;

      function go(n) {
        if (n < 0) n = slides.length - 1;
        if (n >= slides.length) n = 0;
        cur = n;
        track.style.transform = 'translateX(' + (cur * -100) + '%)';
        slides.forEach(function(s, i) { s.classList.toggle('is-active', i === cur); });
        dots.forEach(function(d, i) { d.classList.toggle('is-active', i === cur); });
      }
      function start() { timer = setInterval(function() { go(cur + 1); }, 5500); }
      function reset() { clearInterval(timer); start(); }

      if (nextBtn) nextBtn.addEventListener('click', function() { go(cur + 1); reset(); });
      if (prevBtn) prevBtn.addEventListener('click', function() { go(cur - 1); reset(); });
      dots.forEach(function(d, i) { d.addEventListener('click', function() { go(i); reset(); }); });

      var tx = 0;
      track.addEventListener('touchstart', function(e) { tx = e.changedTouches[0].screenX; clearInterval(timer); }, {passive:true});
      track.addEventListener('touchend', function(e) {
        var diff = e.changedTouches[0].screenX - tx;
        if (Math.abs(diff) > 50) go(cur + (diff < 0 ? 1 : -1));
        start();
      }, {passive:true});

      start();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHeroSlider);
    } else {
      initHeroSlider();
    }
  })();
</script>

{% schema %}
{
  "name": "Hero Slider",
  "max_blocks": 6,
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Product Slide",
      "settings": [
        { "type": "product", "id": "product", "label": "Select Product" },
        { "type": "text", "id": "tagline", "label": "Tagline", "default": "The New Meta" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Slider",
      "blocks": [
        { "type": "slide", "settings": { "tagline": "The New Meta" } },
        { "type": "slide", "settings": { "tagline": "Budget King" } },
        { "type": "slide", "settings": { "tagline": "Top Choice" } }
      ]
    }
  ]
}
{% endschema %}
