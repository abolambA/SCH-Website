<section class="section section-2 featured-products container">
  <div class="section-header reveal text-center">
    <span class="section-eyebrow font-display text-uppercase" style="display:block; font-weight:700; font-size:1rem; letter-spacing:2px; margin-bottom:8px;">Top Rated</span>
    <h2 class="section-title">Best <span class="title-underline">Sellers</span></h2>
  </div>

  <div class="grid grid--4-col">
    {%- assign collection = collections[section.settings.collection] -%}
    {%- if collection and collection.products.size > 0 -%}
      {%- for product in collection.products limit: 4 -%}
        <div class="grid__item reveal">
          {% render 'product-card', product: product %}
        </div>
      {%- endfor -%}
    {%- else -%}
      <!-- Placeholder state -->
      {%- for i in (1..4) -%}
        <div class="grid__item reveal">
          {% render 'product-card' %}
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>

  <div class="section-footer text-center mt-4 reveal">
    <a href="{{ collection.url | default: routes.all_products_collection_url }}" class="btn btn-ghost">View All Products</a>
  </div>
</section>

<style>
  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-title {
    display: inline-block;
    position: relative;
    font-size: 2.5rem;
  }

  .title-underline {
    position: relative;
  }

  .title-underline::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 100%;
    height: 4px;
    background-color: var(--color-primary);
    transform: skewX(-15deg);
  }
</style>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ]
}
{% endschema %}
