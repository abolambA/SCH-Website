{%- if section.settings.show_announcement -%}
  <div class="announcement-bar">
    <div class="announcement-bar__marquee">
      <div class="announcement-bar__content">
        {%- for i in (1..3) -%}
          <span>{{ section.settings.text }}</span>
          <span class="announcement-bar__divider">·</span>
        {%- endfor -%}
      </div>
      <div class="announcement-bar__content" aria-hidden="true">
        {%- for i in (1..3) -%}
          <span>{{ section.settings.text }}</span>
          <span class="announcement-bar__divider">·</span>
        {%- endfor -%}
      </div>
    </div>
  </div>

  <style>
    .announcement-bar {
      background-color: var(--color-secondary); /* Orange */
      color: #FFFFFF;
      overflow: hidden;
      white-space: nowrap;
      position: relative;
      font-family: var(--font-display);
      font-weight: 600;
      font-size: 0.9rem;
      letter-spacing: 1px;
      text-transform: uppercase;
    }
    .announcement-bar__marquee {
      display: flex;
    }
    .announcement-bar__content {
      display: flex;
      padding: 0.6rem 0;
      animation: marquee 25s linear infinite;
    }
    .announcement-bar:hover .announcement-bar__content {
      animation-play-state: paused;
    }
    .announcement-bar__content span {
      padding: 0 1rem;
    }
  </style>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show Announcement",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Free shipping on orders over 100 USD · Community-curated selection · Trusted by UAE cubers · Fast delivery across the Middle East"
    }
  ]
}
{% endschema %}
