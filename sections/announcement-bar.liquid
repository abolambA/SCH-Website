<div class="announcement-bar" data-section="{{ section.id }}">
  <div class="announcement-track">
    {% for block in section.blocks %}
      <div class="announcement-item">
        <span class="announcement-icon">✦</span>
        <span class="announcement-text">{{ block.settings.text }}</span>
      </div>
    {% else %}
      <div class="announcement-item"><span class="announcement-icon">✦</span><span class="announcement-text">Free GCC Shipping on orders over $40</span></div>
      <div class="announcement-item"><span class="announcement-icon">✦</span><span class="announcement-text">New Arrival: GAN 16 MagLev Max</span></div>
      <div class="announcement-item"><span class="announcement-icon">✦</span><span class="announcement-text">Use code SCH for 15% off</span></div>
    {% endfor %}
    <!-- Duplicate for seamless scroll -->
    {% for block in section.blocks %}
      <div class="announcement-item" aria-hidden="true">
        <span class="announcement-icon">✦</span>
        <span class="announcement-text">{{ block.settings.text }}</span>
      </div>
    {% else %}
      <div class="announcement-item" aria-hidden="true"><span class="announcement-icon">✦</span><span class="announcement-text">Free GCC Shipping on orders over $40</span></div>
      <div class="announcement-item" aria-hidden="true"><span class="announcement-icon">✦</span><span class="announcement-text">New Arrival: GAN 16 MagLev Max</span></div>
      <div class="announcement-item" aria-hidden="true"><span class="announcement-icon">✦</span><span class="announcement-text">Use code SCH for 15% off</span></div>
    {% endfor %}
  </div>
</div>

<style>
.announcement-bar {
  background: linear-gradient(90deg, #071726, #0a2239, #071726);
  border-bottom: 1px solid rgba(255,208,0,0.15);
  border-top: 1px solid rgba(255,208,0,0.05);
  padding: 12px 0; overflow: hidden; display: flex; white-space: nowrap;
}
.announcement-track {
  display: flex; gap: 3rem;
  animation: scrollAnnounce 25s linear infinite;
}
.announcement-track:hover { animation-play-state: paused; }
.announcement-item {
  display: inline-flex; align-items: center; gap: 10px;
  font-family: 'Rajdhani', sans-serif; font-weight: 700;
  font-size: 1.05rem; letter-spacing: 1px; color: white;
}
.announcement-icon { color: #FFD000; font-size: 1.2rem; }
@keyframes scrollAnnounce { 0% { transform: translateX(0); } 100% { transform: translateX(calc(-50% - 1.5rem)); } }
</style>

{% schema %}
{
  "name": "Scrolling Banner",
  "blocks": [
    { "type": "announcement", "name": "Announcement", "settings": [ { "type": "text", "id": "text", "label": "Text" } ] }
  ],
  "presets": [ { "name": "Scrolling Banner" } ]
}
{% endschema %}
