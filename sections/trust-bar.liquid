<section class="trust-bar">
  <div class="container trust-bar__inner">
    <div class="trust-item reveal">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="trust-icon"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
      <span class="trust-label font-display">FAST SHIPPING</span>
    </div>
    <div class="trust-divider"></div>
    <div class="trust-item reveal" style="transition-delay:60ms">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="trust-icon"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
      <span class="trust-label font-display">CURATED BY CUBERS</span>
    </div>
    <div class="trust-divider"></div>
    <div class="trust-item reveal" style="transition-delay:120ms">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="trust-icon"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
      <span class="trust-label font-display">EXPERT SUPPORT</span>
    </div>
    <div class="trust-divider"></div>
    <div class="trust-item reveal" style="transition-delay:180ms">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="trust-icon"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
      <span class="trust-label font-display">SECURE CHECKOUT</span>
    </div>
  </div>
</section>

<style>
  .trust-bar {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 1.4rem 0;
  }
  .trust-bar__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    flex-wrap: wrap;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0.6rem 2rem;
    flex: 1;
    min-width: 180px;
    justify-content: center;
  }
  .trust-icon { color: var(--color-primary); flex-shrink: 0; }
  .trust-label {
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-text);
    white-space: nowrap;
    line-height: 1;
  }
  .trust-divider {
    width: 1px;
    height: 28px;
    background: var(--color-border);
    flex-shrink: 0;
  }
  @media (max-width: 768px) {
    .trust-bar__inner { gap: 0; }
    .trust-item { padding: 0.6rem 1rem; min-width: 140px; }
    .trust-divider { display: none; }
    .trust-label { font-size: 0.72rem; }
  }
  @media (max-width: 480px) {
    .trust-bar__inner { display: grid; grid-template-columns: 1fr 1fr; gap: 0; }
    .trust-item { border-bottom: 1px solid var(--color-border); padding: 0.8rem 1rem; }
    .trust-item:nth-child(odd) { border-right: 1px solid var(--color-border); }
    .trust-divider { display: none; }
  }
</style>

{% schema %}
{
  "name": "Trust Bar",
  "settings": []
}
{% endschema %}
