<script>
/* Mobile menu — runs immediately on parse, no defer needed */
(function(){
  function boot(){
    var toggle  = document.getElementById('mobile-menu-toggle');
    var drawer  = document.getElementById('mobileMenu');
    var overlay = document.getElementById('mobileMenuOverlay');
    var closeBtn= document.getElementById('mobile-menu-close');
    if(!toggle||!drawer||!overlay){ return false; }

    function open(){
      drawer.classList.add('is-open');
      overlay.classList.add('is-visible');
      document.body.style.overflow='hidden';
      toggle.setAttribute('aria-expanded','true');
    }
    function close(){
      drawer.classList.remove('is-open');
      overlay.classList.remove('is-visible');
      document.body.style.overflow='';
      toggle.setAttribute('aria-expanded','false');
    }

    toggle.addEventListener('click', open);
    if(closeBtn) closeBtn.addEventListener('click', close);
    overlay.addEventListener('click', close);
    document.addEventListener('keydown',function(e){ if(e.key==='Escape') close(); });

    /* Shop accordion */
    var shopTrigger = document.getElementById('mmenu-shop-trigger');
    var shopInner   = document.getElementById('mmenu-shop-inner');
    if(shopTrigger && shopInner){
      shopTrigger.addEventListener('click',function(){
        var isOpen = shopInner.style.maxHeight && shopInner.style.maxHeight !== '0px';
        if(isOpen){
          shopInner.style.maxHeight='0';
          var c=shopTrigger.querySelector('.mmenu-caret');
          if(c) c.style.transform='';
        } else {
          shopInner.style.maxHeight=shopInner.scrollHeight+'px';
          var c=shopTrigger.querySelector('.mmenu-caret');
          if(c) c.style.transform='rotate(180deg)';
        }
      });
    }

    /* Search overlay */
    var searchTrigger = document.getElementById('search-overlay-trigger');
    var searchOverlay = document.getElementById('search-overlay');
    var searchClose   = document.getElementById('search-close');
    var searchInput   = document.getElementById('SearchInput');
    if(searchTrigger && searchOverlay){
      searchTrigger.addEventListener('click',function(e){
        e.preventDefault();
        searchOverlay.classList.add('active');
        searchOverlay.setAttribute('aria-hidden','false');
        setTimeout(function(){ if(searchInput) searchInput.focus(); },100);
      });
    }
    if(searchClose){
      searchClose.addEventListener('click',function(){
        searchOverlay.classList.remove('active');
        searchOverlay.setAttribute('aria-hidden','true');
      });
    }
    return true;
  }

  if(!boot()) document.addEventListener('DOMContentLoaded', boot);
})();
</script>

<style>
/* ===== HEADER ===== */
.sticky-header {
  position:sticky; top:0; z-index:1000;
  background:rgba(7,23,38,0.97);
  border-bottom:1px solid rgba(255,255,255,0.07);
  backdrop-filter:blur(12px); -webkit-backdrop-filter:blur(12px);
}
.header__inner {
  display:flex;
  align-items:center;
  height:64px;
  gap:1rem;
}

/* Logo */
.nav-logo-wrap { display:flex; align-items:center; gap:10px; text-decoration:none; flex-shrink:0; }
.nav-logo-img  { height:34px; width:auto; display:block; }
.nav-logo-text { font-family:var(--font-display); font-weight:700; font-size:1.05rem; color:#fff; white-space:nowrap; line-height:1; }
@media(max-width:380px){ .nav-logo-text { display:none; } }

/* ===== DESKTOP NAV ===== */
.header__nav {
  flex:1;
  display:flex !important;
  justify-content:center;
  align-items:center;
  height:64px;
  overflow:visible;
}
.header__menu {
  list-style:none; margin:0; padding:0;
  display:flex;
  align-items:center;
  height:100%;
  gap:0;
}
.header__menu-item {
  display:inline-flex;
  align-items:center;
  position:relative;
  height:100%;
}
.header__menu-link {
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:4px;
  padding:0 1rem;
  height:100%;
  font-family:var(--font-display);
  font-weight:700;
  font-size:0.92rem;
  color:#fff;
  text-transform:uppercase;
  letter-spacing:0.08em;
  text-decoration:none;
  white-space:nowrap;
  transition:color 0.2s;
  background:none; border:none; cursor:pointer; line-height:1;
  vertical-align:middle;
  box-sizing:border-box;
  outline:none;
}
.header__menu-link--shop-btn {
  appearance:none;
  -webkit-appearance:none;
  display:inline-flex !important;
  align-items:center !important;
  height:100% !important;
  vertical-align:middle !important;
  line-height:1 !important;
  padding-top:0 !important;
  padding-bottom:0 !important;
  margin-top:0 !important;
  margin-bottom:0 !important;
}
.header__menu-link:hover { color:#FFD000; }
.header__menu-caret { flex-shrink:0; transition:transform 0.2s; opacity:0.6; }
.header__menu-item--has-mega:hover .header__menu-caret { transform:rotate(180deg); }

/* Mega menu */
.header__menu-item--has-mega { position:static; }
.mega-menu {
  position:fixed; top:64px; left:0; right:0; width:100%;
  background:#0D1E2E; border-bottom:2px solid #FFD000;
  box-shadow:0 20px 40px rgba(0,0,0,0.5);
  opacity:0; transform:translateY(-8px); pointer-events:none;
  transition:opacity 0.2s,transform 0.2s; z-index:999;
}
.header__menu-item--has-mega:hover .mega-menu { opacity:1; transform:translateY(0); pointer-events:all; }
.mega-menu-inner {
  max-width:1400px; margin:0 auto;
  display:grid; grid-template-columns:repeat(5,1fr);
  gap:2rem; padding:28px 24px 20px;
}
.mega-col-heading { font-family:var(--font-display); font-weight:700; font-size:0.83rem; text-transform:uppercase; letter-spacing:0.12em; margin:0 0 12px; padding-bottom:8px; border-bottom:1px solid rgba(255,255,255,0.08); }
.mega-menu ul { list-style:none; margin:0; padding:0; }
.mega-menu ul li a { display:block; padding:5px 0; font-size:0.84rem; color:#8899AA; text-decoration:none; transition:color 0.15s,padding-left 0.15s; }
.mega-menu ul li a:hover { color:#fff; padding-left:4px; }
.mega-footer { grid-column:1/-1; border-top:1px solid rgba(255,255,255,0.08); padding-top:16px; text-align:center; }

/* Right icons */
.header__icons { display:flex; align-items:center; gap:0.6rem; flex-shrink:0; margin-left:auto; }
.header__icon-btn { background:none; border:none; color:#fff; cursor:pointer; position:relative; transition:color 0.2s; display:inline-flex; align-items:center; gap:4px; padding:0; text-decoration:none; line-height:1; }
.header__icon-btn:hover { color:#FFD000; }
.lang-label { font-family:var(--font-display); font-size:0.8rem; font-weight:700; letter-spacing:0.5px; line-height:1; }
.header-cart-badge { position:absolute; top:-8px; right:-10px; background:#FFD000; color:#071726; font-family:var(--font-display); font-size:0.68rem; font-weight:900; min-width:17px; height:17px; border-radius:9px; display:flex; align-items:center; justify-content:center; padding:0 3px; border:2px solid #071726; line-height:1; }

/* Hamburger */
.header__hamburger {
  background:none; border:none; padding:6px; cursor:pointer;
  flex-direction:column; justify-content:center; align-items:center; gap:5px;
  width:40px; height:40px;
  display:none !important;
}
.show-on-mobile { display:none !important; }
.hamburger-bar { display:block; width:22px; height:2px; background:#fff; border-radius:2px; transition:all 0.3s; }

/* Responsive show/hide */
.hide-on-mobile { display:flex; }
@media(max-width:1023px){
  .hide-on-mobile  { display:none !important; }
  .show-on-mobile  { display:flex !important; }
  .header__hamburger { display:flex !important; }
}

/* ===== SEARCH OVERLAY ===== */
.search-overlay {
  position:absolute; top:100%; left:0; right:0;
  background:#0D1E2E; border-bottom:2px solid #FFD000;
  box-shadow:0 20px 40px rgba(0,0,0,0.5);
  padding:20px 0; opacity:0; transform:translateY(-8px);
  pointer-events:none; transition:all 0.25s ease; z-index:100;
}
.search-overlay.active { opacity:1; transform:translateY(0); pointer-events:all; }
.search-overlay-inner { display:flex; align-items:center; gap:16px; max-width:760px; margin:0 auto; padding:0 1.5rem; }
.search-form { flex-grow:1; display:flex; border-radius:30px; overflow:hidden; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.12); }
.search-input { flex-grow:1; background:transparent; border:none; padding:14px 20px; font-size:1rem; color:#fff; outline:none; }
.search-input::placeholder { color:rgba(255,255,255,0.4); }
.search-submit { background:transparent; border:none; padding:0 16px; cursor:pointer; color:#fff; }
.search-submit:hover { color:#FFD000; }
.search-close { background:none; border:none; color:rgba(255,255,255,0.5); cursor:pointer; padding:4px; }
.search-close:hover { color:#fff; }

/* ===== MOBILE MENU OVERLAY ===== */
.mobile-menu-overlay {
  position:fixed; inset:0; z-index:9998;
  background:rgba(0,0,0,0.6);
  opacity:0; pointer-events:none;
  transition:opacity 0.35s ease;
  backdrop-filter:blur(2px); -webkit-backdrop-filter:blur(2px);
}
.mobile-menu-overlay.is-visible { opacity:1; pointer-events:all; }

/* ===== MOBILE MENU DRAWER ===== */
.mobile-menu-drawer {
  position:fixed;
  top:0; left:0; bottom:0;
  width:min(320px,88vw);
  background:#071726;
  z-index:9999;
  transform:translateX(-110%);
  transition:transform 0.38s cubic-bezier(0.16,1,0.3,1);
  display:flex; flex-direction:column;
  overflow-y:auto;
  border-right:1px solid rgba(255,208,0,0.12);
  will-change:transform;
  visibility:visible;
}
.mobile-menu-drawer.is-open {
  transform:translateX(0) !important;
}
.mmenu-header {
  display:flex; justify-content:space-between; align-items:center;
  padding:16px 20px;
  border-bottom:1px solid rgba(255,255,255,0.07);
  background:rgba(255,208,0,0.04);
  flex-shrink:0;
}
.mmenu-logo { display:flex; align-items:center; text-decoration:none; }
.mmenu-close {
  background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.12);
  border-radius:50%; width:38px; height:38px; color:#fff;
  display:flex; align-items:center; justify-content:center;
  cursor:pointer; transition:background 0.2s; flex-shrink:0;
}
.mmenu-close:hover { background:rgba(255,255,255,0.15); }
.mmenu-nav { flex:1; padding:8px 0; }
.mmenu-link {
  display:flex; align-items:center; gap:12px;
  padding:15px 20px;
  font-family:var(--font-display); font-weight:700; font-size:1rem;
  color:#fff; text-decoration:none; text-transform:uppercase; letter-spacing:0.06em;
  border-bottom:1px solid rgba(255,255,255,0.05);
  transition:color 0.15s,background 0.15s;
  background:none; border-top:none; border-left:none; border-right:none;
  border-bottom:1px solid rgba(255,255,255,0.05);
  width:100%; cursor:pointer; text-align:left;
}
.mmenu-link:hover,.mmenu-link:focus { color:#FFD000; background:rgba(255,208,0,0.04); }
.mmenu-link svg { opacity:0.6; flex-shrink:0; }
.mmenu-accordion { border-bottom:1px solid rgba(255,255,255,0.05); }
.mmenu-accordion-trigger { justify-content:space-between; border-bottom:none !important; width:100%; }
.mmenu-caret { transition:transform 0.3s ease; flex-shrink:0; opacity:0.6; }
.mmenu-accordion-content { padding:4px 20px 16px; }
.mmenu-section-label { font-family:var(--font-display); font-size:0.65rem; text-transform:uppercase; letter-spacing:2px; color:#FFD000; font-weight:700; margin:0 0 6px; padding-top:4px; }
.mmenu-sub-link { display:block; padding:9px 0; color:rgba(255,255,255,0.65); font-size:0.9rem; text-decoration:none; border-bottom:1px solid rgba(255,255,255,0.03); transition:color 0.15s; }
.mmenu-sub-link:hover { color:#FFD000; }
.mmenu-footer { padding:16px 20px; border-top:1px solid rgba(255,255,255,0.07); margin-top:auto; }
.mmenu-lang-row { display:flex; justify-content:center; }
.mmenu-lang-btn { display:flex; align-items:center; gap:8px; color:rgba(255,255,255,0.6); font-size:0.88rem; text-decoration:none; transition:color 0.2s; padding:8px 0; }
.mmenu-lang-btn:hover { color:#FFD000; }

[dir="rtl"] .mobile-menu-drawer { left:auto; right:0; transform:translateX(110%); border-right:none; border-left:1px solid rgba(255,208,0,0.12); }
[dir="rtl"] .mobile-menu-drawer.is-open { transform:translateX(0) !important; }
</style>

