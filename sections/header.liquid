              <div class="mega-footer">
                <a href="{{ routes.all_products_collection_url }}" class="btn btn-purchase" style="width: 100%;">View All Products →</a>
              </div>
            </div>
          </div>
        </li>

        <li><a href="/pages/about" class="header__menu-link">About</a></li>
        <li><a href="/pages/contact" class="header__menu-link">Contact</a></li>
      </ul>
    </nav>

    <!-- Icons -->
    <div class="header__icons">
      <!-- Language Switcher -->
      <div class="header__language-switcher hide-on-mobile" style="position: relative;">
        <button class="header__icon-btn" aria-label="Change Language" id="lang-toggle" onclick="toggleLanguage()" style="display: flex; align-items: center; gap: 4px;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
          <span class="font-display hide-on-mobile lang-current" style="font-size: 0.9rem;">EN</span>
        </button>
      </div>

      <button class="header__icon-btn search-toggle" aria-label="Search" id="search-overlay-trigger">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      </button>
      
      <!-- Account Login/Register -->
      {%- if customer -%}
        <a href="{{ routes.account_url }}" class="header__icon-btn hide-on-mobile" aria-label="Account">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="color-primary" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        </a>
      {%- else -%}
        <a href="{{ routes.account_login_url }}" class="header__icon-btn hide-on-mobile" aria-label="Sign In">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        </a>
      {%- endif -%}
      <a href="{{ routes.cart_url }}" class="header__icon-btn" data-cart-trigger aria-label="Cart">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
        <span class="header-cart-badge">0</span>
      </a>
      
      <!-- Mobile Hamburger -->
      <button class="header__icon-btn header__hamburger show-on-mobile" id="mobile-menu-toggle" aria-label="Menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>
    </div>

  </div>

  <!-- Mobile Menu Overlay -->
  <div class="mobile-menu" id="mobileMenu">
    <div class="mobile-menu-header">
      <span class="font-display" style="font-size: 1.5rem; font-weight: 900;">{{ shop.name }}</span>
      <button class="mobile-menu-close" id="mobile-menu-close">✕</button>
    </div>
    <div class="mobile-menu-links">
      <a href="{{ routes.all_products_collection_url }}" class="mobile-menu-link">Shop <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg></a>
      <a href="/pages/about" class="mobile-menu-link">About <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg></a>
      <a href="/pages/contact" class="mobile-menu-link">Contact <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg></a>
      {%- if customer -%}
        <a href="{{ routes.account_url }}" class="mobile-menu-link">Account <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg></a>
      {% else %}
        <a href="{{ routes.account_login_url }}" class="mobile-menu-link">Sign In <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg></a>
      {% endif %}
      <div style="padding: 16px 24px;">
        <button class="header__icon-btn" aria-label="Change Language" onclick="toggleLanguage()" style="display: flex; align-items: center; gap: 8px;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
          <span class="font-display lang-current" style="font-size: 1.2rem; font-weight:700;">EN</span>
        </button>
      </div>
    </div>
    <div class="mobile-menu-footer">
      <a href="https://wa.me/000000000" class="mobile-whatsapp-btn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
        Message us on WhatsApp
      </a>
    </div>
  </div>

  <!-- Search Overlay -->
  <div class="search-overlay" id="search-overlay">
    <div class="container search-overlay-inner">
      <form action="{{ routes.search_url }}" method="get" role="search" class="search-form">
        <input type="hidden" name="type" value="product">
        <input class="search-input font-display"
          type="search"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="Search for cubes, brands, or accessories..."
          id="SearchInput"
          autocomplete="off">
        <button type="submit" class="search-submit" aria-label="Submit Search">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="color-primary" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        </button>
      </form>
      <button class="search-close" id="search-close" aria-label="Close Search">✕</button>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Mobile menu toggle
      const mobileToggle = document.getElementById('mobile-menu-toggle');
      const mobileMenu = document.getElementById('mobileMenu');
      const mobileClose = document.getElementById('mobile-menu-close');

      if(mobileToggle && mobileMenu) {
        mobileToggle.addEventListener('click', () => {
          mobileMenu.classList.add('open');
          document.body.style.overflow = 'hidden';
        });
      }

      if(mobileClose && mobileMenu) {
        mobileClose.addEventListener('click', () => {
          mobileMenu.classList.remove('open');
          document.body.style.overflow = '';
        });
      }

      // Search Overlay toggle
      const searchTrigger = document.getElementById('search-overlay-trigger');
      const searchOverlay = document.getElementById('search-overlay');
      const searchClose = document.getElementById('search-close');
      const searchInput = document.getElementById('SearchInput');

      if(searchTrigger && searchOverlay) {
        searchTrigger.addEventListener('click', () => {
          searchOverlay.classList.add('active');
          setTimeout(() => searchInput.focus(), 100);
        });
      }

      if(searchClose && searchOverlay) {
        searchClose.addEventListener('click', () => {
          searchOverlay.classList.remove('active');
        });
      }
    });

    // We expose toggleLanguage in a global scope in i18n.js, so the onclick will work
  </script>
</header>

<style>
  .sticky-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(7, 23, 38, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    transition: transform 0.3s ease;
  }
  
  /* Search Overlay CSS */
  .search-overlay {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: #0D1E2E;
    border-bottom: 2px solid var(--color-primary);
    box-shadow: 0 20px 40px rgba(0,0,0,0.5);
    padding: 24px 0;
    opacity: 0;
    transform: translateY(-10px);
    pointer-events: none;
    transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
    z-index: 100;
  }

  .search-overlay.active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: all;
  }

  .search-overlay-inner {
    display: flex;
    align-items: center;
    gap: 20px;
    max-width: 800px;
    margin: 0 auto;
  }

  .search-form {
    flex-grow: 1;
    display: flex;
    position: relative;
    border-radius: 30px;
    overflow: hidden;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
  }

  .search-input {
    flex-grow: 1;
    background: transparent;
    border: none;
    padding: 16px 24px;
    font-size: 1.25rem;
    color: var(--color-text);
    outline: none;
  }
  
  .search-input::placeholder {
    color: var(--color-text-muted);
  }

  .search-submit {
    background: transparent;
    border: none;
    padding: 0 20px;
    cursor: pointer;
    transition: transform 0.2s;
  }
  
  .search-submit:hover {
    transform: scale(1.1);
  }

  .search-close {
    background: none;
    border: none;
    color: var(--color-text-muted);
    font-size: 1.5rem;
    cursor: pointer;
    transition: color 0.2s;
  }
  
  .search-close:hover {
    color: #fff;
  }

  
  .header__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 64px;
  }

  .nav-logo-wrap {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 10px;
    text-decoration: none;
    line-height: 1;
  }
  
  .nav-logo-img {
    height: 36px;
    width: auto;
    display: block;
    flex-shrink: 0;
  }

  .nav-logo-text {
    font-family: var(--font-display, 'Rajdhani', sans-serif);
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--color-text);
    white-space: nowrap;
    line-height: 1;
    margin-top: 2px;
  }

  @media (max-width: 480px) {
    .nav-logo-text {
      display: none;
    }
  }

  .header__nav {
    height: 100%;
  }

  .header__menu {
    display: flex;
    gap: 2rem;
    list-style: none;
    height: 100%;
    align-items: center;
  }

  .header__menu-link {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--color-text);
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: color var(--transition-fast);
    padding: 1rem 0;
  }

  .header__menu-link:hover {
    color: var(--color-primary);
  }

  /* Mega Menu */
  .header__menu-item--has-mega {
    position: static;
  }

  .mega-menu {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: #0D1E2E;
    border-bottom: 2px solid #FFD000;
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    opacity: 0;
    transform: translateY(-8px);
    pointer-events: none;
    transition: opacity 0.2s, transform 0.2s;
    z-index: 200;
  }

  .header__menu-item--has-mega:hover .mega-menu {
    opacity: 1;
    transform: translateY(0);
    pointer-events: all;
  }

  .mega-menu-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 2rem;
    padding: 28px 24px 20px;
    text-align: left;
  }

  .mega-brand-heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .mega-menu ul {
    list-style: none;
  }

  .mega-menu ul li a {
    display: block;
    padding: 5px 0;
    font-size: 0.85rem;
    color: #8899AA;
    text-decoration: none;
    transition: color 0.15s, padding-left 0.15s;
  }

  .mega-menu ul li a:hover {
    color: #FFFFFF;
    padding-left: 4px;
  }

  .mega-footer {
    grid-column: 1 / -1;
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-top: 16px;
    margin-top: 8px;
    text-align: center;
  }

  .header__icons {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .header__icon-btn {
    background: none;
    border: none;
    color: var(--color-text);
    cursor: pointer;
    position: relative;
    transition: color var(--transition-fast);
  }

  .header__icon-btn:hover {
    color: var(--color-primary);
  }

  .header-cart-badge {
    position: absolute;
    top: -8px;
    right: -10px;
    background-color: var(--color-primary);
    color: var(--color-bg);
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    min-width: 18px;
    height: 18px;
    border-radius: 9px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 4px;
    border: 2px solid var(--color-bg);
  }

  .hide-on-mobile { display: block; }
  .show-on-mobile { display: none; }

  @media (max-width: 1023px) {
    .hide-on-mobile { display: none; }
    .show-on-mobile { display: block; }

    .header__nav.is-open-mobile {
      display: block !important;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: rgba(7, 23, 38, 0.98);
      padding: 1rem;
      border-bottom: 1px solid var(--color-border);
      height: auto;
      max-height: 80vh;
      overflow-y: auto;
    }
    .header__nav.is-open-mobile .header__menu {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    .mega-menu {
      position: static;
      box-shadow: none;
      border-bottom: none;
      opacity: 1;
      transform: none;
      pointer-events: all;
      display: none;
      background: rgba(255,255,255,0.02);
      margin-top: 1rem;
    }
    .header__menu-item--has-mega:hover .mega-menu, .header__menu-item--has-mega.is-active .mega-menu {
      display: block;
    }
    .mega-menu-inner {
      grid-template-columns: 1fr;
      padding: 1rem;
    }
  }
</style>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}
