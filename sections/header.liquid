<style>
  #shopify-section-{{ section.id }} {
    position: sticky;
    top: 0;
    z-index: 1000 !important;
    overflow: visible !important;
  }
</style>

<header class="header sticky-header">
  <div class="container header__inner">
    <!-- Logo -->
    <a href="{{ routes.root_url }}" class="nav-logo-wrap">
      {%- if settings.logo != blank -%}
        <img src="{{ settings.logo | image_url: width: 160 }}" alt="{{ shop.name | escape }}" class="nav-logo-img" loading="eager">
      {%- else -%}
        <img src="{{ 'Logo removed BG.png' | asset_url }}" alt="SpeedCubeHub Logo" class="nav-logo-img" loading="eager">
      {%- endif -%}
      <span class="nav-logo-text">{{ shop.name | default: 'SpeedCubeHub' }}</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="header__nav hide-on-mobile">
      <ul class="header__menu">
        <li><a href="{{ routes.root_url }}" class="header__menu-link">Home</a></li>
        
        <!-- Mega Menu: Shop by Brand -->
        <li class="header__menu-item--has-mega">
          <a href="{{ routes.all_products_collection_url }}" class="header__menu-link" aria-expanded="false" aria-controls="mega-menu-shop">
            Shop
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-left: 4px;"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </a>
          <div id="mega-menu-shop" class="header__mega-menu mega-menu" role="navigation">
            <div class="mega-menu-inner">
              
              <div class="mega-col">
                <h3 class="mega-brand-heading" style="color: var(--color-primary)">GAN</h3>
                <ul>
                  <li><a href="/collections/gan-3x3">3×3</a></li>
                  <li><a href="/collections/gan-2x2">2×2</a></li>
                  <li><a href="/collections/gan-pyraminx">Pyraminx</a></li>
                  <li><a href="/collections/gan-smart-cubes">Smart Cubes</a></li>
                  <li><a href="/collections/gan-accessories">Accessories</a></li>
                </ul>
              </div>

              <div class="mega-col">
                <h3 class="mega-brand-heading" style="color: var(--color-accent)">MoYu</h3>
                <ul>
                  <li><a href="/collections/moyu-3x3">3×3</a></li>
                  <li><a href="/collections/moyu-2x2">2×2</a></li>
                  <li><a href="/collections/moyu-4x4">4×4</a></li>
                  <li><a href="/collections/moyu-5x5">5×5</a></li>
                  <li><a href="/collections/moyu-big-cubes">Big Cubes</a></li>
                  <li><a href="/collections/moyu-accessories">Accessories</a></li>
                </ul>
              </div>

              <div class="mega-col">
                <h3 class="mega-brand-heading" style="color: var(--color-secondary)">YJ / YongJun</h3>
                <ul>
                  <li><a href="/collections/yj-3x3">3×3</a></li>
                  <li><a href="/collections/yj-2x2">2×2</a></li>
                  <li><a href="/collections/yj-pyraminx">Pyraminx</a></li>
                  <li><a href="/collections/yj-megaminx">Megaminx</a></li>
                  <li><a href="/collections/yj-budget-series">Budget Series</a></li>
                </ul>
              </div>

              <div class="mega-col">
                <h3 class="mega-brand-heading" style="color: #a78bfa">QiYi</h3>
                <ul>
                  <li><a href="/collections/qiyi-3x3">3×3</a></li>
                  <li><a href="/collections/qiyi-2x2">2×2</a></li>
                  <li><a href="/collections/qiyi-4x4">4×4</a></li>
                  <li><a href="/collections/qiyi-pyraminx">Pyraminx</a></li>
                  <li><a href="/collections/qiyi-skewb">Skewb</a></li>
                  <li><a href="/collections/qiyi-accessories">Accessories</a></li>
                </ul>
              </div>

              <div class="mega-col">
                <h3 class="mega-brand-heading" style="color: #10b981">Other Brands</h3>
                <ul>
                  <li><a href="/collections/dayan">DaYan</a></li>
                  <li><a href="/collections/x-man">X-Man</a></li>
                  <li><a href="/collections/shengshou">ShengShou</a></li>
                  <li><a href="/collections/z-cube">Z-Cube</a></li>
                  <li><a href="/collections/all-brands">All Brands</a></li>
                </ul>
              </div>

              <div class="mega-col">
                <h3 class="mega-brand-heading" style="color: var(--color-primary)">Shop by Type</h3>
                <ul>
                  <li><a href="/collections/3x3">3×3</a></li>
                  <li><a href="/collections/2x2">2×2</a></li>
                  <li><a href="/collections/4x4">4×4</a></li>
                  <li><a href="/collections/5x5">5×5</a></li>
                  <li><a href="/collections/pyraminx">Pyraminx</a></li>
                  <li><a href="/collections/megaminx">Megaminx</a></li>
                  <li><a href="/collections/skewb">Skewb</a></li>
                  <li><a href="/collections/square-1">Square-1</a></li>
                  <li><a href="/collections/clock">Clock</a></li>
                  <li><a href="/collections/accessories">Accessories</a></li>
                  <li><a href="/collections/timers">Timers</a></li>
                  <li><a href="/collections/lubricants">Lubricants</a></li>
                </ul>
