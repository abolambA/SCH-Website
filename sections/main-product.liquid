<section class="product-page section" id="MainProduct-{{ section.id }}" data-section="{{ section.id }}">
  <div class="container">
    <div class="product-layout">

      <!-- Left: Image Gallery -->
      <div class="product-gallery reveal" id="ProductGallery-{{ section.id }}">
        <div class="product-gallery__main">
          {%- if product.selected_or_first_available_variant.featured_image -%}
            {%- assign main_image = product.selected_or_first_available_variant.featured_image -%}
          {%- else -%}
            {%- assign main_image = product.featured_image -%}
          {%- endif -%}

          <div class="product-gallery__image-wrapper">
            {%- if product.media.size > 1 -%}
              <button class="pg-nav-btn pg-nav-prev" aria-label="Previous image" data-dir="-1">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
              </button>
            {%- endif -%}
            {%- if main_image -%}
              <img src="{{ main_image | image_url: width: 900 }}" alt="{{ main_image.alt | escape }}" class="product-gallery__image" id="main-product-image-{{ section.id }}" loading="eager">
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'product-gallery__image' }}
            {%- endif -%}
            {%- if product.media.size > 1 -%}
              <button class="pg-nav-btn pg-nav-next" aria-label="Next image" data-dir="1">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
              </button>
            {%- endif -%}
          </div>

          <div class="product-gallery__badges">
            {%- if product.compare_at_price > product.price -%}
              <span class="product-badge product-badge--sale">SALE</span>
            {%- endif -%}
            {%- if product.tags contains 'New' -%}
              <span class="product-badge product-badge--new">NEW</span>
            {%- endif -%}
          </div>
        </div>

        {%- if product.media.size > 1 -%}
          <div class="product-gallery__thumbnails" id="ProductThumbs-{{ section.id }}">
            {%- for media in product.media -%}
              <button class="product-gallery__thumb {% if forloop.first %}is-active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="View image {{ forloop.index }}">
                <img src="{{ media.preview_image | image_url: width: 200 }}" alt="{{ media.alt | escape }}" loading="lazy">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <!-- Right: Product Info -->
      <div class="product-info reveal" style="transition-delay:100ms;">
        <div class="product-info__sticky">

          <h1 class="product__title font-display">{{ product.title }}</h1>
          <div class="product__vendor">{{ product.vendor }}</div>

          <div class="product__price-container">
            <span class="product__price font-display color-primary" id="product-price-{{ section.id }}">
              {{ product.selected_or_first_available_variant.price | money }}
            </span>
            {%- if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price -%}
              <span class="product__compare-price" id="product-compare-price-{{ section.id }}">
                {{ product.selected_or_first_available_variant.compare_at_price | money }}
              </span>
              <span class="product__badge-sale">SAVE {{ product.selected_or_first_available_variant.compare_at_price | minus: product.selected_or_first_available_variant.price | money }}</span>
            {%- endif -%}
          </div>

          {%- unless product.has_only_default_variant -%}
            <div class="product__variants">
              {%- for option in product.options_with_values -%}
                <fieldset class="variant-fieldset">
                  <legend class="variant-legend">{{ option.name }}</legend>
                  <div class="variant-pills">
                    {%- for value in option.values -%}
                      <input type="radio"
                        id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                        name="{{ option.name }}"
                        value="{{ value | escape }}"
                        form="product-form-{{ section.id }}"
                        {% if option.selected_value == value %}checked{% endif %}
                        class="visually-hidden">
                      <label for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}" class="variant-pill">{{ value }}</label>
                    {%- endfor -%}
                  </div>
                </fieldset>
              {%- endfor -%}
            </div>
          {%- endunless -%}

          {%- form 'product', product, id: "product-form-#{section.id}", class: 'product-form' -%}
            <input type="hidden" name="id" id="variant-id-{{ section.id }}" value="{{ product.selected_or_first_available_variant.id }}">
            <div class="product__actions">
              <div class="product__quantity">
                <button type="button" class="qty-btn minus" data-form="{{ section.id }}">−</button>
                <input type="number" name="quantity" value="1" min="1" class="qty-input" id="qty-{{ section.id }}">
                <button type="button" class="qty-btn plus" data-form="{{ section.id }}">+</button>
              </div>
              <button type="button" class="btn btn-purchase product-form__submit btn--full"
                id="atc-btn-{{ section.id }}"
                {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
                data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                data-qty-id="qty-{{ section.id }}">
                {%- if product.selected_or_first_available_variant.available -%}
                  <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
                  Add to Cart
                {%- else -%}
                  Sold Out
                {%- endif -%}
              </button>
            </div>
            <div class="product__dynamic-checkout">{{ form | payment_button }}</div>
          {%- endform -%}

          <div class="product__trust">
            <div class="trust-icons-row">
              <div class="trust-icon-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
                <span>Free Shipping</span>
              </div>
              <div class="trust-icon-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                <span>Secure Payment</span>
              </div>
              <div class="trust-icon-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><polyline points="3 3 3 8 8 8"></polyline></svg>
                <span>Easy Returns</span>
              </div>
            </div>
          </div>

          <div class="product-tabs">
            <div class="product-tabs__nav">
              <button class="product-tab__btn is-active" data-target="tab-desc-{{ section.id }}">Description</button>
              <button class="product-tab__btn" data-target="tab-specs-{{ section.id }}">Specs</button>
              <button class="product-tab__btn" data-target="tab-shipping-{{ section.id }}">Shipping</button>
            </div>
            <div class="product-tabs__content">
              <div class="product-tab__panel is-active" id="tab-desc-{{ section.id }}">
                <div class="rte product-description">{{ product.description }}</div>
              </div>
              <div class="product-tab__panel" id="tab-specs-{{ section.id }}">
                <div class="rte">
                  <table class="specs-table">
                    <tbody>
                      <tr><th>Vendor</th><td>{{ product.vendor }}</td></tr>
                      <tr><th>Type</th><td>{{ product.type | default: '—' }}</td></tr>
                      {%- for tag in product.tags -%}
                        {%- if tag contains ':' -%}
                          {%- assign parts = tag | split: ':' -%}
                          <tr><th>{{ parts[0] | capitalize }}</th><td>{{ parts[1] | strip }}</td></tr>
                        {%- endif -%}
                      {%- endfor -%}
                    </tbody>
                  </table>
                </div>
              </div>
              <div class="product-tab__panel" id="tab-shipping-{{ section.id }}">
                <div class="rte" style="color:var(--color-text-muted);font-size:0.9rem;line-height:1.8;">
                  <p>✅ <strong>UAE</strong>: 1–2 business days</p>
                  <p>✅ <strong>GCC (KSA, Kuwait, Qatar, Bahrain, Oman)</strong>: 3–5 business days</p>
                  <p>🎁 <strong>Free shipping</strong> on orders over 100 AED</p>
                  <p>📦 Orders placed before 2 PM are dispatched the same day</p>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .product-page { padding-top: 2rem; padding-bottom: 4rem; }
  .product-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 3.5rem; align-items: start; }
  @media (max-width: 900px) { .product-layout { grid-template-columns: 1fr; gap: 2rem; } }

  /* Gallery */
  .product-gallery__main {
    position: relative;
    background: var(--color-surface); border: 1px solid var(--color-border);
    border-radius: 16px; overflow: hidden; margin-bottom: 0.8rem;
  }
  .product-gallery__image-wrapper {
    position: relative; width: 100%; aspect-ratio: 4/3; overflow: hidden;
  }
  .product-gallery__image { width: 100%; height: 100%; object-fit: contain; padding: 1.2rem; display: block; }

  /* Gallery arrows */
  .pg-nav-btn {
    position: absolute; top: 50%; transform: translateY(-50%); z-index: 5;
    width: 38px; height: 38px;
    background: rgba(7,23,38,0.85); border: 1.5px solid rgba(255,255,255,0.2);
    border-radius: 50%; color: #fff;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: all 0.2s; padding: 0;
    backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
  }
  .pg-nav-btn:hover { background: #FFD000; border-color: #FFD000; color: #071726; }
  .pg-nav-prev { left: 10px; }
  .pg-nav-next { right: 10px; }

  .product-gallery__badges {
    position: absolute; top: 12px; left: 12px;
    display: flex; flex-direction: column; gap: 5px; z-index: 3;
  }
  .product-badge {
    display: inline-block; padding: 3px 8px; font-family: var(--font-display);
    font-size: 0.7rem; font-weight: 800; letter-spacing: 1px; border-radius: 5px;
  }
  .product-badge--sale { background: #ef4444; color: #fff; }
  .product-badge--new { background: var(--color-primary); color: #071726; }

  .product-gallery__thumbnails {
    display: flex; gap: 0.5rem; overflow-x: auto;
    padding: 0.5rem 0; scrollbar-width: none;
    flex-wrap: wrap;
  }
  .product-gallery__thumbnails::-webkit-scrollbar { display: none; }
  .product-gallery__thumb {
    width: 64px; height: 64px; flex-shrink: 0;
    border: 2px solid transparent; border-radius: 8px;
    background: var(--color-surface); padding: 4px; cursor: pointer; transition: border-color 0.2s;
  }
  .product-gallery__thumb img { width: 100%; height: 100%; object-fit: contain; border-radius: 5px; }
  .product-gallery__thumb.is-active, .product-gallery__thumb:hover { border-color: var(--color-primary); }

  /* Product Info */
  .product-info__sticky { position: sticky; top: 80px; }
  .product__title { font-size: clamp(1.6rem, 2.5vw, 2.2rem); margin-bottom: 0.3rem; line-height: 1.2; }
  .product__vendor { color: var(--color-text-muted); font-size: 0.88rem; margin-bottom: 1rem; }
  .product__price-container { display: flex; align-items: baseline; gap: 0.8rem; flex-wrap: wrap; margin-bottom: 1.4rem; }
  .product__price { font-size: 1.9rem; font-weight: 900; }
  .product__compare-price { color: var(--color-text-muted); text-decoration: line-through; font-size: 1rem; }
  .product__badge-sale { background: #ef4444; color: #fff; font-family: var(--font-display); font-size: 0.72rem; font-weight: 800; padding: 3px 8px; border-radius: 5px; letter-spacing: 0.5px; }

  .product__variants { margin-bottom: 1.4rem; }
  .variant-fieldset { border: none; padding: 0; margin: 0 0 1rem; }
  .variant-legend { font-size: 0.8rem; color: var(--color-text-muted); margin-bottom: 0.5rem; display: block; text-transform: uppercase; letter-spacing: 1px; }
  .variant-pills { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .variant-pill { display: inline-flex; align-items: center; padding: 0.45rem 0.9rem; border: 1.5px solid var(--color-border); border-radius: 50px; cursor: pointer; transition: all 0.2s; font-size: 0.88rem; font-weight: 600; color: var(--color-text-muted); }
  input[type="radio"]:checked + .variant-pill { background: var(--color-primary); color: #071726; border-color: var(--color-primary); }

  .product__actions { display: flex; gap: 0.8rem; margin-bottom: 0.8rem; align-items: stretch; }
  .product__quantity { display: flex; align-items: center; border: 1.5px solid var(--color-border); border-radius: 10px; background: var(--color-surface); flex-shrink: 0; }
  .qty-btn { background: none; border: none; color: var(--color-text); width: 38px; height: 46px; cursor: pointer; font-size: 1.2rem; transition: color 0.2s; display: flex; align-items: center; justify-content: center; }
  .qty-btn:hover { color: var(--color-primary); }
  .qty-input { width: 42px; height: 46px; background: none; border: none; text-align: center; color: var(--color-text); font-size: 1rem; font-weight: 700; -moz-appearance: textfield; padding: 0; }
  .qty-input::-webkit-outer-spin-button, .qty-input::-webkit-inner-spin-button { -webkit-appearance: none; }

  .product__dynamic-checkout { margin: 0.8rem 0 1rem; }

  .product__trust { padding-top: 1rem; border-top: 1px solid var(--color-border); margin-bottom: 1.2rem; }
  .trust-icons-row { display: flex; justify-content: space-between; gap: 0.5rem; }
  .trust-icon-item { display: flex; align-items: center; gap: 5px; font-size: 0.78rem; color: var(--color-text-muted); }

  .product-tabs { border-top: 1px solid var(--color-border); padding-top: 1rem; }
  .product-tabs__nav { display: flex; border-bottom: 1px solid var(--color-border); gap: 0; }
  .product-tab__btn { background: none; border: none; border-bottom: 2px solid transparent; padding: 0.7rem 1rem; color: var(--color-text-muted); font-family: var(--font-display); font-weight: 700; font-size: 0.9rem; cursor: pointer; transition: all 0.2s; margin-bottom: -1px; }
  .product-tab__btn.is-active { color: var(--color-text); border-bottom-color: var(--color-primary); }
  .product-tab__btn:hover { color: var(--color-text); }
  .product-tabs__content { padding-top: 1rem; }
  .product-tab__panel { display: none; }
  .product-tab__panel.is-active { display: block; }
  .product-description { color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.8; }
  .product-description p { margin-bottom: 0.8rem; }

  .specs-table { width: 100%; border-collapse: collapse; }
  .specs-table th, .specs-table td { padding: 0.6rem 0; border-bottom: 1px solid var(--color-border); font-size: 0.88rem; }
  .specs-table th { color: var(--color-text); width: 40%; font-weight: 700; }
  .specs-table td { color: var(--color-text-muted); }

  @media (max-width: 768px) {
    .product-page { padding-top: 1rem; padding-bottom: 2rem; }
    .product-info__sticky { position: static; }
    .product__actions { flex-direction: row; }
    .trust-icons-row { flex-wrap: wrap; gap: 0.8rem; }
    .trust-icon-item { min-width: 100px; }
  }
  @media (max-width: 480px) {
    .product__actions { flex-direction: column; }
    .product__quantity { width: fit-content; }
  }
</style>

<script>
(function() {
  function initProductGallery(sectionId) {
    var gallery = document.getElementById('ProductGallery-' + sectionId);
    if (!gallery) return;

    var mainImg = document.getElementById('main-product-image-' + sectionId);
    var thumbsContainer = document.getElementById('ProductThumbs-' + sectionId);
    var thumbs = thumbsContainer ? thumbsContainer.querySelectorAll('.product-gallery__thumb') : [];
    var curIdx = 0;

    function goToIndex(idx) {
      if (idx < 0) idx = thumbs.length - 1;
      if (idx >= thumbs.length) idx = 0;
      curIdx = idx;
      var clickedThumb = thumbs[idx];
      if (!clickedThumb) return;
      var thumbImg = clickedThumb.querySelector('img');
      if (thumbImg && mainImg) {
        mainImg.src = thumbImg.src.replace('width=200', 'width=900');
      }
      thumbs.forEach(function(t) { t.classList.remove('is-active'); });
      clickedThumb.classList.add('is-active');
    }

    // Thumb clicks
    thumbs.forEach(function(thumb, idx) {
      thumb.addEventListener('click', function() { goToIndex(idx); });
    });

    // Arrow buttons
    var prevBtn = gallery.querySelector('.pg-nav-prev');
    var nextBtn = gallery.querySelector('.pg-nav-next');
    if (prevBtn) prevBtn.addEventListener('click', function() { goToIndex(curIdx - 1); });
    if (nextBtn) nextBtn.addEventListener('click', function() { goToIndex(curIdx + 1); });

    // Swipe
    var wrapper = gallery.querySelector('.product-gallery__image-wrapper');
    if (wrapper && thumbs.length > 1) {
      var tStart = 0;
      wrapper.addEventListener('touchstart', function(e) { tStart = e.changedTouches[0].screenX; }, {passive:true});
      wrapper.addEventListener('touchend', function(e) {
        var diff = e.changedTouches[0].screenX - tStart;
        if (Math.abs(diff) > 40) goToIndex(curIdx + (diff < 0 ? 1 : -1));
      }, {passive:true});
    }
  }

  function initProductTabs(sectionId) {
    var tabs = document.querySelectorAll('[data-target="tab-desc-' + sectionId + '"]').length
      ? document.querySelectorAll('.product-tab__btn')
      : [];
    var panels = document.querySelectorAll('.product-tab__panel');
    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        tabs.forEach(function(t) { t.classList.remove('is-active'); });
        panels.forEach(function(p) { p.classList.remove('is-active'); });
        tab.classList.add('is-active');
        var panel = document.getElementById(tab.dataset.target);
        if (panel) panel.classList.add('is-active');
      });
    });
  }

  function initQtyBtns() {
    document.querySelectorAll('.qty-btn.minus').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var formId = btn.dataset.form;
        var input = document.getElementById('qty-' + formId);
        if (input) { var v = parseInt(input.value) || 1; if (v > 1) input.value = v - 1; }
      });
    });
    document.querySelectorAll('.qty-btn.plus').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var formId = btn.dataset.form;
        var input = document.getElementById('qty-' + formId);
        if (input) { var v = parseInt(input.value) || 1; input.value = v + 1; }
      });
    });
  }

  function initATCBtn() {
    document.querySelectorAll('.product-form__submit').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var variantId = btn.dataset.variantId;
        var qtyInput = document.getElementById(btn.dataset.qtyId);
        var qty = qtyInput ? parseInt(qtyInput.value) || 1 : 1;
        if (variantId && typeof CartDrawer !== 'undefined') {
          CartDrawer.addProduct(variantId, qty, btn);
        }
      });
    });
  }

  function init() {
    var sectionEl = document.querySelector('[id^="MainProduct-"]');
    if (!sectionEl) return;
    var sectionId = sectionEl.id.replace('MainProduct-', '');
    initProductGallery(sectionId);
    initProductTabs(sectionId);
    initQtyBtns();
    initATCBtn();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

{% schema %}
{
  "name": "Product Page",
  "settings": []
}
{% endschema %}
