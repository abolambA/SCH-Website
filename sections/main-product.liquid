<section class="product-page container section pb-6" id="MainProduct-{{ section.id }}" data-section="{{ section.id }}">
  <div class="product-grid grid grid--2-col">
    
    <!-- Left: Image Gallery -->
    <div class="product-gallery grid__item reveal">
      <div class="product-gallery__main">
        {%- if product.selected_or_first_available_variant.featured_image -%}
          {%- assign main_image = product.selected_or_first_available_variant.featured_image -%}
        {%- else -%}
          {%- assign main_image = product.featured_image -%}
        {%- endif -%}
        
        {%- if main_image -%}
          <div class="product-gallery__image-wrapper zoom-container">
            <button class="gallery-nav-btn prev" aria-label="Previous Image" onclick="navigateGallery(-1)">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
            </button>
            <img src="{{ main_image | image_url: width: 1000 }}" alt="{{ main_image.alt | escape }}" class="product-gallery__image zoom-image" id="main-product-image">
            <button class="gallery-nav-btn next" aria-label="Next Image" onclick="navigateGallery(1)">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </button>
          </div>
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'product-gallery__image' }}
        {%- endif -%}

        <!-- Badges -->
        <div class="product-gallery__badges">
          {%- if product.compare_at_price > product.price -%}
            {% render 'badge', type: 'sale', text: 'SALE' %}
          {%- endif -%}
          {%- if product.tags contains 'New' -%}
            {% render 'badge', type: 'new', text: 'NEW' %}
          {%- endif -%}
        </div>
      </div>

      <!-- Thumbnails -->
      {%- if product.media.size > 1 -%}
        <div class="product-gallery__thumbnails mt-4">
          {%- for media in product.media -%}
            <button class="product-gallery__thumb {% if media.id == main_image.id %}is-active{% endif %}" data-media-id="{{ media.id }}">
              <img src="{{ media.preview_image | image_url: width: 200 }}" alt="{{ media.alt | escape }}">
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Right: Buy Box -->
    <div class="product-info grid__item reveal" style="transition-delay: 100ms;">
      <div class="product-info__sticky">
        <h1 class="product__title font-display">{{ product.title }}</h1>
        <div class="product__meta mt-2 mb-4">
          <p class="font-body text-muted">{{ product.vendor }}</p>
        </div>

        <div class="product__price-container mb-4">
          <span class="product__price color-primary font-display" id="product-price-{{ section.id }}">
            {{ product.selected_or_first_available_variant.price | money }}
          </span>
          {%- if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price -%}
            <span class="product__compare-price ml-2" id="product-compare-price-{{ section.id }}">
              {{ product.selected_or_first_available_variant.compare_at_price | money }}
            </span>
          {%- endif -%}
        </div>

        {%- if settings.enable_countdown_timer -%}
          <div class="product__timer mb-4">
            <span class="color-secondary font-display" style="font-weight: 700;">Deal ends in 12:45:00</span>
          </div>
        {%- endif -%}

        {%- unless product.has_only_default_variant -%}
          <div class="product__variants mb-4">
            {%- for option in product.options_with_values -%}
              <fieldset class="variant-fieldset mb-3">
                <legend class="font-body mb-2">{{ option.name }}</legend>
                <div class="variant-pills">
                  {%- for value in option.values -%}
                    <input type="radio" id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                          name="{{ option.name }}"
                          value="{{ value | escape }}"
                          form="product-form-{{ section.id }}"
                          {% if option.selected_value == value %}checked{% endif %}
                          class="visually-hidden">
                    <label for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}" class="variant-pill">
                      {{ value }}
                    </label>
                  {%- endfor -%}
                </div>
              </fieldset>
            {%- endfor -%}
          </div>
        {%- endunless -%}

        {%- form 'product', product, id: 'product-form-{{ section.id }}', class: 'form product-form' -%}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          
          <div class="product__actions mb-4">
            <div class="product__quantity">
              <button type="button" class="qty-btn minus">-</button>
              <input type="number" name="quantity" value="1" min="1" class="qty-input text-center">
              <button type="button" class="qty-btn plus">+</button>
            </div>
            
            <button type="button" class="btn btn-purchase product-form__submit btn--full"
              {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
              onclick="CartDrawer.addProduct({{ product.selected_or_first_available_variant.id }}, document.querySelector('.qty-input').value, this)">
              {%- if product.selected_or_first_available_variant.available -%}
                Add to Cart
              {%- else -%}
                Sold Out
              {%- endif -%}
            </button>
          </div>
          
          <div class="product__dynamic-checkout mb-4">
            {{ form | payment_button }}
          </div>
        {%- endform -%}

        <div class="product__trust mb-4 border-top pt-4">
          <div class="trust-icons">
            <div class="trust-icon-item">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="color-primary"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
              <span>Free Shipping</span>
            </div>
            <div class="trust-icon-item">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="color-primary"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
              <span>Secure Payment</span>
            </div>
            <div class="trust-icon-item">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="color-primary"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><polyline points="3 3 3 8 8 8"></polyline></svg>
              <span>Easy Returns</span>
            </div>
          </div>
        </div>

        <!-- Tabs -->
        <div class="product-tabs mt-6 border-top pt-4">
          <div class="product-tabs__nav">
            <button class="product-tab__btn is-active" data-target="tab-desc">Description</button>
            <button class="product-tab__btn" data-target="tab-specs">Specs & Feel</button>
            <button class="product-tab__btn" data-target="tab-shipping">Shipping</button>
            <div class="product-tabs__indicator"></div>
          </div>
          
          <div class="product-tabs__content mt-4">
            <div class="product-tab__panel is-active" id="tab-desc">
              <div class="rte font-body text-muted">
                {{ product.description }}
              </div>
            </div>
            <div class="product-tab__panel" id="tab-specs">
              <div class="rte font-body text-muted">
                <table class="specs-table w-100">
                  <tbody>
                    <tr><th>Size</th><td>56mm</td></tr>
                    <tr><th>Weight</th><td>73g</td></tr>
                    <tr><th>Magnet Strength</th><td>Adjustable</td></tr>
                    <tr><th>Plastic</th><td>Stickerless (Bright)</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
            <div class="product-tab__panel" id="tab-shipping">
              <div class="rte font-body text-muted">
                <p>Fast delivery across UAE in 1-2 business days. GCC delivery in 3-5 days.</p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  .product-gallery__main {
    position: relative;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    padding: 2rem;
    overflow: hidden;
  }

  .zoom-container {
    width: 100%;
    aspect-ratio: 1/1;
    overflow: hidden;
    position: relative;
    cursor: zoom-in;
  }

  .zoom-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.3s ease;
  }

  .zoom-container:hover .zoom-image {
    transform: scale(1.5);
    cursor: zoom-in;
  }

  .gallery-nav-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.8);
    border: none;
    border-radius: 50%;
    width: 40px; height: 40px;
    display: flex; align-items: center; justify-content: center;
    color: var(--color-bg);
    cursor: pointer;
    z-index: 10;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    transition: all 0.2s;
  }
  .gallery-nav-btn:hover {
    background: var(--color-primary);
    transform: translateY(-50%) scale(1.1);
  }
  .gallery-nav-btn.prev { left: 1rem; }
  .gallery-nav-btn.next { right: 1rem; }

  .product-gallery__badges {
    position: absolute;
    top: 1.5rem;
    left: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .product-gallery__thumbnails {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    padding-bottom: 0.5rem;
    scrollbar-width: thin;
  }

  .product-gallery__thumb {
    width: 80px;
    height: 80px;
    flex-shrink: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    background: var(--color-surface);
    padding: 0.5rem;
    cursor: pointer;
    transition: border-color var(--transition-fast);
  }

  .product-gallery__thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .product-gallery__thumb.is-active,
  .product-gallery__thumb:hover {
    border-color: var(--color-primary);
  }

  .product-info__sticky {
    position: sticky;
    top: 100px;
  }

  .product__title {
    font-size: 2.5rem;
    line-height: 1.1;
  }

  .product__price {
    font-size: 2rem;
  }

  .product__compare-price {
    color: var(--color-secondary);
    text-decoration: line-through;
    font-size: 1.2rem;
    font-family: var(--font-body);
  }

  .variant-fieldset {
    border: none;
    padding: 0;
    margin: 0;
  }

  .variant-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .variant-pill {
    display: inline-block;
    padding: 0.6rem 1.2rem;
    border: 1px solid var(--color-border);
    border-radius: 50px;
    cursor: pointer;
    transition: all var(--transition-fast);
    font-weight: 600;
  }

  input[type="radio"]:checked + .variant-pill {
    background-color: var(--color-primary);
    color: var(--color-bg);
    border-color: var(--color-primary);
  }

  .product__actions {
    display: flex;
    gap: 1rem;
  }

  .product__quantity {
    display: flex;
    align-items: center;
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    background-color: var(--color-surface);
  }

  .qty-btn {
    background: none;
    border: none;
    color: var(--color-text);
    width: 40px;
    height: 48px;
    cursor: pointer;
    font-size: 1.2rem;
  }

  .qty-input {
    width: 50px;
    height: 48px;
    background: none;
    border: none;
    padding: 0;
    -moz-appearance: textfield;
  }
  .qty-input::-webkit-outer-spin-button,
  .qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
  }

  .trust-icons {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }

  .trust-icon-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .product-tabs__nav {
    display: flex;
    gap: 2rem;
    border-bottom: 1px solid var(--color-border);
    position: relative;
  }

  .product-tab__btn {
    background: none;
    border: none;
    padding: 1rem 0;
    color: var(--color-text-muted);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    cursor: pointer;
    transition: color var(--transition-fast);
  }

  .product-tab__btn.is-active,
  .product-tab__btn:hover {
    color: var(--color-text);
  }

  .product-tabs__indicator {
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100px; /* Dynamics via JS usually */
    height: 3px;
    background-color: var(--color-primary);
    transition: transform 0.3s ease, width 0.3s ease;
  }

  .product-tab__panel {
    display: none;
    animation: fadeIn 0.3s ease;
  }

  .product-tab__panel.is-active {
    display: block;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(5px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .specs-table th {
    text-align: left;
    padding: 0.8rem 0;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
    width: 40%;
  }

  .specs-table td {
    padding: 0.8rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .border-top { border-top: 1px solid var(--color-border); }
  .pt-4 { padding-top: 1.5rem; }
  .w-100 { width: 100%; }

  @media (max-width: 1023px) {
    .product-grid {
      grid-template-columns: 1fr;
    }
    .product-info__sticky {
      position: static;
      margin-top: 2rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Zoom logic
    const img = document.querySelector('.zoom-image');
    const container = document.querySelector('.zoom-container');
    if(container && img) {
      container.addEventListener('mousemove', (e) => {
        const { left, top, width, height } = container.getBoundingClientRect();
        const x = (e.clientX - left) / width * 100;
        const y = (e.clientY - top) / height * 100;
        img.style.transformOrigin = `${x}% ${y}%`;
      });
      container.addEventListener('mouseleave', () => {
        img.style.transformOrigin = `center center`;
      });
    }

    // Thumbnail click logic
    const thumbs = document.querySelectorAll('.product-gallery__thumb');
    if (thumbs.length > 0) {
      thumbs.forEach((thumb, idx) => {
        thumb.dataset.index = idx;
        thumb.addEventListener('click', function() {
          const newSrc = this.querySelector('img').src.replace('width=200', 'width=1000');
          if (img) img.src = newSrc;
          
          thumbs.forEach(t => t.classList.remove('is-active'));
          this.classList.add('is-active');
        });
      });
    }

    // Carousel arrows logic
    window.navigateGallery = function(direction) {
      const activeThumb = document.querySelector('.product-gallery__thumb.is-active');
      if (!activeThumb || thumbs.length === 0) return;
      
      let currentIndex = parseInt(activeThumb.dataset.index, 10);
      let newIndex = currentIndex + direction;
      
      if (newIndex < 0) newIndex = thumbs.length - 1;
      if (newIndex >= thumbs.length) newIndex = 0;
      
      thumbs[newIndex].click();
    };

    // Tabs logic
    const tabs = document.querySelectorAll('.product-tab__btn');
    const panels = document.querySelectorAll('.product-tab__panel');
    const indicator = document.querySelector('.product-tabs__indicator');
    
    // Set initial indicator width
    if(indicator && tabs.length > 0) {
      indicator.style.width = tabs[0].offsetWidth + 'px';
    }

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('is-active'));
        panels.forEach(p => p.classList.remove('is-active'));
        
        tab.classList.add('is-active');
        document.getElementById(tab.dataset.target).classList.add('is-active');
        
        // Move indicator
        if(indicator) {
          indicator.style.width = tab.offsetWidth + 'px';
          indicator.style.transform = `translateX(${tab.offsetLeft}px)`;
        }
      });
    });

    // Qty logic
    const btnMinus = document.querySelector('.qty-btn.minus');
    const btnPlus = document.querySelector('.qty-btn.plus');
    const inputQty = document.querySelector('.qty-input');
    
    if(btnMinus && btnPlus && inputQty) {
      btnMinus.addEventListener('click', () => {
        let val = parseInt(inputQty.value) || 1;
        if(val > 1) inputQty.value = val - 1;
      });
      btnPlus.addEventListener('click', () => {
        let val = parseInt(inputQty.value) || 1;
        inputQty.value = val + 1;
      });
    }
  });
</script>

{% schema %}
{
  "name": "Product Page",
  "settings": []
}
{% endschema %}
