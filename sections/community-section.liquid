<section class="section community-section container">
  <div class="community-card reveal text-center">
    <h2 class="community-card__title">Built by cubers, <span class="color-primary">for cubers.</span></h2>
    <p class="community-card__desc font-body text-muted mx-auto" style="max-width: 800px; margin-left: auto; margin-right: auto; margin-bottom: 2rem;">
      SpeedCubeHub isn't just a store — it's the home of the Middle East cubing community. Founded by the leaders of the Syrian Speedcubing Community, every product we sell is tested and approved by speedcubers.
    </p>
    <a href="/pages/about" class="btn btn-info">Meet the Community</a>
  </div>
</section>

<style>
  .community-card {
    background-color: var(--color-surface);
    border-radius: var(--border-radius);
    padding: 6rem 2rem;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    position: relative;
    overflow: hidden;
    border-top: 4px solid var(--color-primary);
  }

  .community-card::before {
    content: '';
    position: absolute;
    top: -50%;
    left: 25%;
    width: 50%;
    height: 200%;
    background: radial-gradient(circle, var(--color-glow) 0%, transparent 60%);
    opacity: 0.5;
    pointer-events: none;
  }

  .community-card__title {
    font-size: 3.5rem;
    margin-bottom: 1.5rem;
  }

  .community-card__desc {
    font-size: 1.2rem;
    line-height: 1.8;
  }

  @media (max-width: 768px) {
    .community-card {
      padding: 4rem 1.5rem;
    }
    .community-card__title {
      font-size: 2.5rem;
    }
  }
</style>

{% schema %}
{
  "name": "Community Section",
  "settings": []
}
{% endschema %}
