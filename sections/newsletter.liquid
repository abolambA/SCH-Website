<section class="section newsletter text-center">
  <div class="container reveal">
    <h2 class="newsletter__title">Join the SCH Community</h2>
    <p class="newsletter__desc font-body text-muted">Stay ahead of the curve. Get exclusive access to new drops, restocks, and community events.</p>
    
    <form class="newsletter__form" action="#" method="post">
      <div class="newsletter__input-group">
        <input type="email" placeholder="Enter your email address" class="newsletter__input" required aria-label="Email address">
        <button type="submit" class="btn btn-purchase newsletter__btn">Subscribe</button>
      </div>
      <p class="newsletter__fine-print font-body text-muted mt-4">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1" style="vertical-align: middle;"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
        No spam. Just new drops, deals, and community updates.
      </p>
    </form>
  </div>
</section>

<style>
  .newsletter {
    background-color: var(--color-bg);
    padding: 6rem 0;
    border-top: 1px solid var(--color-border);
  }

  .newsletter__title {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .newsletter__desc {
    font-size: 1.1rem;
    margin-bottom: 2.5rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .newsletter__form {
    max-width: 500px;
    margin: 0 auto;
  }

  .newsletter__input-group {
    display: flex;
    gap: 0.5rem;
  }

  .newsletter__input {
    flex: 1;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 1rem 1.5rem;
    border-radius: var(--border-radius);
    color: var(--color-text);
  }

  .newsletter__input:focus {
    border-color: var(--color-primary);
    outline: none;
    box-shadow: 0 0 0 2px rgba(255, 208, 0, 0.2);
  }

  .newsletter__btn {
    padding: 1rem 2rem;
  }

  .newsletter__fine-print {
    font-size: 0.8rem;
    opacity: 0.7;
  }

  @media (max-width: 767px) {
    .newsletter__input-group {
      flex-direction: column;
    }
    .newsletter__btn {
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Newsletter",
  "settings": []
}
{% endschema %}
