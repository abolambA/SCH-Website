<section class="section section-3 authorized-dealers container">
  <div class="section-header text-center reveal">
    <span class="section-eyebrow font-display text-uppercase" style="display:block; font-weight:700; font-size:1rem; letter-spacing:2px; margin-bottom:8px;">Our Partners</span>
    <h2 class="section-title font-display" style="font-size: 1.8rem; letter-spacing: 1px; text-transform: uppercase;">
      {{ section.settings.title | default: 'Authorized Dealers of Famous Brands' }}
    </h2>
  </div>

  <div class="dealer-grid">
    {%- for block in section.blocks -%}
      <div class="reveal">
        <a href="{{ block.settings.brand_link | default: '#' }}" class="brand-card">
          {%- if block.settings.brand_image != blank -%}
            <img src="{{ block.settings.brand_image | image_url: width: 300 }}" alt="{{ block.settings.brand_name | escape }}" class="brand-logo" loading="lazy">
          {%- else -%}
            <span class="brand-name-fallback">{{ block.settings.brand_name }}</span>
          {%- endif -%}
        </a>
      </div>
    {%- else -%}
      <!-- Fallbacks -->
      {%- assign default_brands = "GAN Cube,MoYu Cube,QiYi,YJ,Speed Stacks" | split: "," -%}
      {%- for brand in default_brands -%}
        <div class="reveal">
          <a href="/collections/all" class="brand-card">
            <span class="brand-name-fallback">{{ brand }}</span>
          </a>
        </div>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</section>

<style>
  .authorized-dealers { padding-top: 4rem; padding-bottom: 4rem; }
  .dealer-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.5rem;
    margin-top: 2rem;
  }
  @media (max-width: 1024px) { .dealer-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 600px) { .dealer-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; } }

  .brand-card {
    background: #0D1E2E; border: 1px solid rgba(255,255,255,0.07);
    border-radius: 12px; padding: 28px 20px;
    display: flex; align-items: center; justify-content: center;
    min-height: 120px; text-decoration: none;
    transition: all 0.25s;
    height: 100%;
  }
  .brand-card:hover {
    border-color: rgba(255,208,0,0.4);
    box-shadow: 0 8px 24px rgba(255,208,0,0.12);
    transform: translateY(-4px);
  }
  .brand-logo {
    max-height: 85px; max-width: 160px;
    width: auto; height: auto; object-fit: contain;
    filter: brightness(0.9);
    transition: filter 0.2s, transform 0.2s;
  }
  .brand-card:hover .brand-logo { filter: brightness(1.1); transform: scale(1.05); }
  .brand-name-fallback {
    font-family: var(--font-display, 'Rajdhani', sans-serif); font-weight: 700;
    font-size: 1.2rem; color: #FFD000; text-align: center;
  }
</style>

{% schema %}
{
  "name": "Authorized Dealers",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Authorized Dealers of Famous Brands"
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        { "type": "text", "id": "brand_name", "label": "Brand Name" },
        { "type": "image_picker", "id": "brand_image", "label": "Brand Logo (Image)" },
        { "type": "url", "id": "brand_link", "label": "Brand Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Authorized Dealers",
      "blocks": [
        { "type": "brand", "settings": { "brand_name": "GAN Cube" } },
        { "type": "brand", "settings": { "brand_name": "MoYu Cube" } },
        { "type": "brand", "settings": { "brand_name": "QiYi" } },
        { "type": "brand", "settings": { "brand_name": "YJ" } },
        { "type": "brand", "settings": { "brand_name": "Speed Stacks" } }
      ]
    }
  ]
}
{% endschema %}
