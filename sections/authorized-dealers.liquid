<section class="authorized-dealers-section" id="authorized-dealers-{{ section.id }}">
  <div class="container">
    <div class="section-header text-center reveal" style="margin-bottom:2.5rem;">
      <p class="section-eyebrow font-display" style="color:var(--color-primary);font-size:0.78rem;letter-spacing:3px;text-transform:uppercase;font-weight:700;margin-bottom:0.6rem;">Our Partners</p>
      <h2 class="font-display" style="font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;text-transform:uppercase;letter-spacing:2px;">
        {{ section.settings.title | default: 'Authorized Dealers of Famous Brands' }}
      </h2>
    </div>

    <div class="brands-grid">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div class="brand-card-wrap reveal" style="transition-delay:{{ forloop.index0 | times: 60 }}ms;" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.brand_link | default: '/collections/all' }}" class="brand-card" aria-label="{{ block.settings.brand_name | default: 'Brand' }}">
              {%- if block.settings.brand_image != blank -%}
                <div class="brand-card__img-wrap">
                  <img src="{{ block.settings.brand_image | image_url: width: 320 }}" alt="{{ block.settings.brand_name | default: 'Brand logo' | escape }}" class="brand-card__logo" loading="lazy">
                </div>
              {%- else -%}
                <div class="brand-card__name-fallback">{{ block.settings.brand_name | default: 'Brand' }}</div>
              {%- endif -%}
              {%- if block.settings.brand_name != blank -%}
                <div class="brand-card__label">{{ block.settings.brand_name }}</div>
              {%- endif -%}
            </a>
          </div>
        {%- endfor -%}
      {%- else -%}

        <!-- GAN Cube -->
        <div class="brand-card-wrap reveal" style="transition-delay:0ms;">
          <a href="/collections/gan" class="brand-card brand-card--gan" aria-label="GAN Cube">
            <div class="brand-card__img-wrap">
              <img src="{{ 'Gan.webp' | asset_url }}" alt="GAN Cube" class="brand-card__logo" loading="lazy"
                onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
              <div class="brand-card__fallback-svg" style="display:none;">
                <svg viewBox="0 0 200 70" xmlns="http://www.w3.org/2000/svg" width="160" height="56">
                  <polygon points="35,5 60,19 60,47 35,61 10,47 10,19" fill="none" stroke="#0052A5" stroke-width="3"/>
                  <text x="75" y="43" font-family="Arial Black,Arial" font-weight="900" font-size="32" fill="#0052A5" letter-spacing="2">GAN</text>
                </svg>
              </div>
            </div>
            <div class="brand-card__label">GAN Cube</div>
          </a>
        </div>

        <!-- MoYu -->
        <div class="brand-card-wrap reveal" style="transition-delay:60ms;">
          <a href="/collections/moyu" class="brand-card brand-card--moyu" aria-label="MoYu Cube">
            <div class="brand-card__img-wrap">
              <img src="{{ 'moyu.avif' | asset_url }}" alt="MoYu Cube" class="brand-card__logo" loading="lazy"
                onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
              <div class="brand-card__fallback-svg" style="display:none;">
                <svg viewBox="0 0 220 70" xmlns="http://www.w3.org/2000/svg" width="180" height="56">
                  <text x="15" y="48" font-family="Arial Black,Arial" font-weight="900" font-size="28" fill="#CC0000">MoYu</text>
                </svg>
              </div>
            </div>
            <div class="brand-card__label">MoYu Cube</div>
          </a>
        </div>

        <!-- QiYi -->
        <div class="brand-card-wrap reveal" style="transition-delay:120ms;">
          <a href="/collections/qiyi" class="brand-card brand-card--qiyi" aria-label="QiYi">
            <div class="brand-card__img-wrap">
              <img src="{{ 'qiyi.webp' | asset_url }}" alt="QiYi" class="brand-card__logo" loading="lazy"
                onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
              <div class="brand-card__fallback-svg" style="display:none;">
                <svg viewBox="0 0 200 70" xmlns="http://www.w3.org/2000/svg" width="160" height="56">
                  <text x="20" y="48" font-family="Arial Black,Arial" font-weight="900" font-size="28" fill="#E31E24">QiYi</text>
                </svg>
              </div>
            </div>
            <div class="brand-card__label">QiYi</div>
          </a>
        </div>

        <!-- YJ -->
        <div class="brand-card-wrap reveal" style="transition-delay:180ms;">
          <a href="/collections/yj" class="brand-card brand-card--yj" aria-label="YJ Cube">
            <div class="brand-card__img-wrap">
              <img src="{{ 'yj.webp' | asset_url }}" alt="YJ" class="brand-card__logo" loading="lazy"
                onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
              <div class="brand-card__fallback-svg" style="display:none;">
                <svg viewBox="0 0 200 70" xmlns="http://www.w3.org/2000/svg" width="160" height="56">
                  <text x="20" y="48" font-family="Arial Black,Arial" font-weight="900" font-size="32" fill="#E8A000">YJ</text>
                </svg>
              </div>
            </div>
            <div class="brand-card__label">YJ</div>
          </a>
        </div>

        <!-- Speed Stacks -->
        <div class="brand-card-wrap reveal" style="transition-delay:240ms;">
          <a href="/collections/speed-stacks" class="brand-card brand-card--speedstacks" aria-label="Speed Stacks">
            <div class="brand-card__img-wrap">
              <img src="{{ 'speed stacks.jpg' | asset_url }}" alt="Speed Stacks" class="brand-card__logo" loading="lazy"
                onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
              <div class="brand-card__fallback-svg" style="display:none;">
                <svg viewBox="0 0 200 70" xmlns="http://www.w3.org/2000/svg" width="160" height="56">
                  <text x="5" y="30" font-family="Arial Black,Arial" font-weight="900" font-size="14" fill="#0066CC">SPEED</text>
                  <text x="5" y="52" font-family="Arial Black,Arial" font-weight="900" font-size="14" fill="#CC0000">STACKS</text>
                </svg>
              </div>
            </div>
            <div class="brand-card__label">Speed Stacks</div>
          </a>
        </div>

      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .authorized-dealers-section { padding:4rem 0; background:var(--color-bg); }
  .brands-grid {
    display:grid;
    grid-template-columns:repeat(5,1fr);
    gap:1.2rem;
  }
  @media(max-width:1100px){ .brands-grid { grid-template-columns:repeat(4,1fr); } }
  @media(max-width:768px)  { .brands-grid { grid-template-columns:repeat(3,1fr); gap:0.9rem; } }
  @media(max-width:480px)  { .brands-grid { grid-template-columns:repeat(2,1fr); gap:0.75rem; } }

  .brand-card {
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    background:#ffffff;
    border:2px solid rgba(0,0,0,0.08);
    border-radius:16px; padding:1.5rem 1rem; min-height:140px;
    text-decoration:none;
    transition:border-color 0.22s,box-shadow 0.22s,transform 0.22s;
    gap:0.6rem; position:relative; overflow:hidden;
    box-shadow:0 2px 12px rgba(0,0,0,0.06);
  }
  .brand-card:hover {
    border-color:#FFD000;
    box-shadow:0 8px 32px rgba(255,208,0,0.25);
    transform:translateY(-6px);
  }
  @media(max-width:480px){ .brand-card { min-height:110px; padding:1rem 0.6rem; } }

  .brand-card__img-wrap {
    display:flex; align-items:center; justify-content:center;
    width:100%; height:76px; overflow:hidden;
  }
  .brand-card__fallback-svg {
    display:none; align-items:center; justify-content:center;
    width:100%; height:100%;
  }
  .brand-card__logo {
    max-width:160px; max-height:72px; width:auto; height:auto;
    object-fit:contain; display:block; margin:0 auto;
    transition:transform 0.2s;
    /* Make logos look good against white card */
    mix-blend-mode:multiply;
  }
  .brand-card:hover .brand-card__logo { transform:scale(1.06); }

  .brand-card__label {
    font-family:var(--font-display); font-weight:700; font-size:0.78rem;
    color:#444; text-align:center; text-transform:uppercase; letter-spacing:0.8px;
    margin-top:0.2rem; transition:color 0.2s;
  }
  .brand-card:hover .brand-card__label { color:#b8960a; }
  .brand-card__name-fallback {
    font-family:var(--font-display); font-weight:800;
    font-size:clamp(1rem,2vw,1.3rem); color:#1A9FE0; text-align:center; letter-spacing:1px;
  }
  /* Per-brand hover accents */
  .brand-card--gan:hover       { border-color:#0052A5; box-shadow:0 8px 32px rgba(0,82,165,0.2); }
  .brand-card--moyu:hover      { border-color:#CC0000; box-shadow:0 8px 32px rgba(204,0,0,0.15); }
  .brand-card--qiyi:hover      { border-color:#E31E24; box-shadow:0 8px 32px rgba(227,30,36,0.15); }
  .brand-card--yj:hover        { border-color:#E8A000; box-shadow:0 8px 32px rgba(232,160,0,0.2); }
  .brand-card--speedstacks:hover { border-color:#0066CC; box-shadow:0 8px 32px rgba(0,102,204,0.2); }
</style>

{% schema %}
{
  "name": "Authorized Dealers",
  "settings": [
    { "type": "text", "id": "title", "label": "Section Heading", "default": "Authorized Dealers of Famous Brands" }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        { "type": "text", "id": "brand_name", "label": "Brand Name" },
        { "type": "image_picker", "id": "brand_image", "label": "Brand Logo" },
        { "type": "url", "id": "brand_link", "label": "Collection Link", "info": "e.g. /collections/gan" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Authorized Dealers",
      "blocks": [
        { "type": "brand", "settings": { "brand_name": "GAN Cube", "brand_link": "/collections/gan" } },
        { "type": "brand", "settings": { "brand_name": "MoYu Cube", "brand_link": "/collections/moyu" } },
        { "type": "brand", "settings": { "brand_name": "QiYi", "brand_link": "/collections/qiyi" } },
        { "type": "brand", "settings": { "brand_name": "YJ", "brand_link": "/collections/yj" } },
        { "type": "brand", "settings": { "brand_name": "Speed Stacks", "brand_link": "/collections/speed-stacks" } }
      ]
    }
  ]
}
{% endschema %}
