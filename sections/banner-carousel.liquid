<section id="banner-carousel-{{ section.id }}" class="banner-carousel-section" data-section-id="{{ section.id }}">
  <div class="banner-carousel-container">
    <div class="banner-carousel-track" id="carousel-track-{{ section.id }}">
      {%- for block in section.blocks -%}
        <div class="banner-carousel-slide" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="banner-slide-link" aria-label="{{ block.settings.label | default: 'View offer' }}">
          {%- endif -%}
          <div class="banner-slide-img-wrap">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 1920 }}"
                srcset="{{ block.settings.image | image_url: width: 600 }} 600w,
                        {{ block.settings.image | image_url: width: 900 }} 900w,
                        {{ block.settings.image | image_url: width: 1400 }} 1400w,
                        {{ block.settings.image | image_url: width: 1920 }} 1920w"
                sizes="100vw"
                alt="{{ block.settings.label | default: shop.name | escape }}"
                class="banner-slide-img"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                draggable="false"
              >
            {%- else -%}
              <div class="banner-slide-placeholder">
                <span>Add a banner image in the theme editor</span>
              </div>
            {%- endif -%}
          </div>
          {%- if block.settings.link != blank -%}
            </a>
          {%- endif -%}
        </div>
      {%- else -%}
        <!-- Default placeholder slides when none configured -->
        <div class="banner-carousel-slide" data-index="0">
          <a href="/collections/all" class="banner-slide-link">
            <div class="banner-slide-placeholder">
              <div style="text-align:center;">
                <p style="font-family:var(--font-display);font-size:1.4rem;color:#FFD000;margin-bottom:0.5rem;">Add Banner Images</p>
                <p style="color:rgba(255,255,255,0.5);font-size:0.9rem;">Go to Theme Editor → Sections → Banner Carousel</p>
              </div>
            </div>
          </a>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.blocks.size > 1 -%}
      <button class="banner-arrow banner-prev" id="banner-prev-{{ section.id }}" aria-label="Previous slide">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>
      <button class="banner-arrow banner-next" id="banner-next-{{ section.id }}" aria-label="Next slide">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
      <div class="banner-dots" id="banner-dots-{{ section.id }}" aria-label="Slide navigation"></div>
    {%- endif -%}
  </div>
</section>

<style>
  .banner-carousel-section {
    position: relative;
    width: 100%;
    background: #000;
    overflow: hidden;
  }
  .banner-carousel-container {
    position: relative;
    width: 100%;
    /* Fixed pixel height for predictable rendering */
    height: 580px;
    overflow: hidden;
  }
  @media (max-width: 1024px) { .banner-carousel-container { height: 420px; } }
  @media (max-width: 768px)  { .banner-carousel-container { height: 260px; } }
  @media (max-width: 480px)  { .banner-carousel-container { height: 200px; } }

  .banner-carousel-track {
    display: flex;
    width: 100%;
    height: 100%;
    will-change: transform;
    transition: transform 0.55s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .banner-carousel-slide {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
    display: block;
  }
  .banner-slide-link {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
  }
  .banner-slide-img-wrap {
    width: 100%;
    height: 100%;
  }
  .banner-slide-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    user-select: none;
    pointer-events: none;
  }
  .banner-slide-placeholder {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, #0a1628, #1a3a5c, #071726);
    display: flex; align-items: center; justify-content: center;
  }

  /* Arrows */
  .banner-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 44px; height: 44px;
    background: rgba(7,23,38,0.65);
    border: 1.5px solid rgba(255,255,255,0.22);
    border-radius: 50%;
    color: rgba(255,255,255,0.9);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
    padding: 0;
  }
  .banner-arrow:hover {
    background: #FFD000;
    border-color: #FFD000;
    color: #071726;
    transform: translateY(-50%) scale(1.08);
  }
  .banner-prev { left: 18px; }
  .banner-next { right: 18px; }
  @media (max-width: 480px) {
    .banner-arrow { width: 34px; height: 34px; }
    .banner-arrow svg { width: 16px; height: 16px; }
    .banner-prev { left: 8px; }
    .banner-next { right: 8px; }
  }

  /* Dots */
  .banner-dots {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    gap: 5px;
    align-items: center;
    padding: 4px 8px;
    background: rgba(0,0,0,0.35);
    border-radius: 20px;
    backdrop-filter: blur(4px);
    line-height: 0;
    width: auto;
    white-space: nowrap;
  }
  /* Use span-based dots (set via JS), not buttons, to avoid browser button sizing issues */
  .banner-dot {
    display: inline-block !important;
    flex: 0 0 auto !important;
    width: 7px !important;
    height: 7px !important;
    min-width: 7px !important;
    max-width: 7px !important;
    min-height: 7px !important;
    max-height: 7px !important;
    border-radius: 50% !important;
    background: rgba(255,255,255,0.4) !important;
    cursor: pointer;
    padding: 0 !important;
    margin: 0 !important;
    border: none !important;
    box-sizing: border-box !important;
    transition: background 0.25s, width 0.25s, border-radius 0.25s !important;
    font-size: 0 !important;
    line-height: 0 !important;
    outline: none;
    vertical-align: middle;
  }
  .banner-dot.is-active {
    background: #FFD000 !important;
    width: 20px !important;
    min-width: 20px !important;
    max-width: 20px !important;
    border-radius: 4px !important;
  }
  @media (max-width: 768px) {
    .banner-dots { bottom: 8px; gap: 4px; padding: 3px 7px; }
    .banner-dot { width: 6px !important; height: 6px !important; min-width:6px !important; max-width:6px !important; min-height:6px !important; max-height:6px !important; }
    .banner-dot.is-active { width: 14px !important; min-width:14px !important; max-width:14px !important; }
  }
</style>

<script>
(function() {
  document.addEventListener('DOMContentLoaded', function() {
    var sectionId = "{{ section.id }}";
    var track = document.getElementById('carousel-track-' + sectionId);
    if (!track) return;
    var slides = track.querySelectorAll('.banner-carousel-slide');
    if (slides.length <= 1) return;

    var prevBtn = document.getElementById('banner-prev-' + sectionId);
    var nextBtn = document.getElementById('banner-next-' + sectionId);
    var dotsContainer = document.getElementById('banner-dots-' + sectionId);
    var currentIndex = 0;
    var autoplayTimer = null;
    var touchStartX = 0;
    var isDragging = false;

    // Build dots
    var dots = [];
    if (dotsContainer) {
      slides.forEach(function(_, i) {
        var dot = document.createElement('button');
        dot.className = 'banner-dot' + (i === 0 ? ' is-active' : '');
        dot.setAttribute('aria-label', 'Go to slide ' + (i + 1));
        dot.setAttribute('type', 'button');
        dot.addEventListener('click', function() { goTo(i); });
        dotsContainer.appendChild(dot);
        dots.push(dot);
      });
    }

    function updateUI() {
      track.style.transform = 'translateX(-' + (currentIndex * 100) + '%)';
      dots.forEach(function(d, i) {
        d.classList.toggle('is-active', i === currentIndex);
      });
    }

    function goTo(idx) {
      currentIndex = ((idx % slides.length) + slides.length) % slides.length;
      updateUI();
      resetAutoplay();
    }

    function startAutoplay() {
      autoplayTimer = setInterval(function() { goTo(currentIndex + 1); }, 6000);
    }
    function resetAutoplay() { clearInterval(autoplayTimer); startAutoplay(); }

    if (prevBtn) prevBtn.addEventListener('click', function() { goTo(currentIndex - 1); });
    if (nextBtn) nextBtn.addEventListener('click', function() { goTo(currentIndex + 1); });

    // Touch/swipe
    track.addEventListener('touchstart', function(e) {
      touchStartX = e.changedTouches[0].clientX;
      isDragging = false;
      clearInterval(autoplayTimer);
    }, { passive: true });
    track.addEventListener('touchmove', function(e) {
      if (Math.abs(e.changedTouches[0].clientX - touchStartX) > 10) isDragging = true;
    }, { passive: true });
    track.addEventListener('touchend', function(e) {
      var diff = e.changedTouches[0].clientX - touchStartX;
      if (isDragging && Math.abs(diff) > 40) {
        goTo(currentIndex + (diff < 0 ? 1 : -1));
      } else {
        startAutoplay();
      }
    }, { passive: true });

    updateUI();
    startAutoplay();
  });
})();
</script>

{% schema %}
{
  "name": "Banner Carousel",
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "limit": 10,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Banner Image (1920×650px recommended)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Click destination (link when banner is clicked)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Accessibility label",
          "info": "Describe the banner for screen readers",
          "default": "Shop now"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Banner Carousel",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
