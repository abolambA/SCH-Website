<!-- Trust Bar -->
<div class="trust-bar display-flex justify-between align-center px-4 py-3" style="background-color: #0A1218; border-top: 1px solid rgba(255,255,255,0.05);">
  <div class="container trust-bar__inner">
    <div class="trust-item">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
      <span class="font-display" data-i18n="trust.shipping">Fast Shipping</span>
    </div>
    <div class="trust-item">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
      <span class="font-display" data-i18n="trust.curated">Curated by Cubers</span>
    </div>
    <div class="trust-item">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
      <span class="font-display" data-i18n="trust.support">Expert Support</span>
    </div>
    <div class="trust-item border-none">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
      <span class="font-display" data-i18n="trust.secure">Secure Checkout</span>
    </div>
  </div>
</div>

<footer class="footer">
  <div class="container footer-grid">
    <!-- Col 1: Brand -->
    <div class="footer-col footer-col--brand">
      {%- if settings.logo != blank -%}
        <img src="{{ settings.logo | image_url: width: 200 }}" alt="{{ shop.name | escape }}" style="max-height: 40px; margin-bottom: 1rem;">
      {%- else -%}
        <h3 class="font-display color-text mb-4" style="font-size: 1.5rem;">SpeedCubeHub</h3>
      {%- endif -%}
      <p class="font-body text-muted mb-4" style="font-size: 0.9rem; max-width: 250px;">
        {{ section.settings.brand_desc | default: "The home of the Middle East cubing community. Tested and approved by speedcubers." }}
      </p>
      <div class="footer__socials">
        <a href="#" class="social-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg></a>
        <a href="#" class="social-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg></a>
        <a href="#" class="social-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33c.53.18 1.94 2 1.94 2s6.88.46 8.6.46 8.6-.46 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.33 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg></a>
      </div>
    </div>
    
    <!-- Col 2: Shop -->
    <div class="footer-col">
      <h4 class="font-display color-primary footer-heading">Shop</h4>
      <ul class="footer-links">
        <li><a href="/collections/3x3">3x3 Cubes</a></li>
        <li><a href="/collections/2x2">2x2 Cubes</a></li>
        <li><a href="/collections/pyraminx">Pyraminx</a></li>
        <li><a href="/collections/megaminx">Megaminx</a></li>
        <li><a href="/collections/accessories">Accessories</a></li>
        <li><a href="/collections/all">All Products</a></li>
      </ul>
    </div>
    
    <!-- Col 3: Brands -->
    <div class="footer-col">
      <h4 class="font-display color-primary footer-heading">Brands</h4>
      <ul class="footer-links">
        <li><a href="/collections/gan">GAN</a></li>
        <li><a href="/collections/moyu">MoYu</a></li>
        <li><a href="/collections/yj">YJ</a></li>
        <li><a href="/collections/qiyi">QiYi</a></li>
        <li><a href="/collections/dayan">DaYan</a></li>
        <li><a href="/collections/all-brands">Other Brands</a></li>
      </ul>
    </div>

    <!-- Col 4: Help -->
    <div class="footer-col">
      <h4 class="font-display color-primary footer-heading">Help</h4>
      <ul class="footer-links">
        <li><a href="/pages/faq">FAQ</a></li>
        <li><a href="/policies/shipping-policy">Shipping Policy</a></li>
        <li><a href="/policies/refund-policy">Returns</a></li>
        <li><a href="/pages/contact">Contact Us</a></li>
        <li><a href="/pages/about">About Us</a></li>
        <li><a href="/account">Track Order</a></li>
      </ul>
    </div>
  </div>

  <!-- Newsletter Band -->
  <div class="newsletter-band pb-4 pt-4 px-4" style="background-color: var(--color-surface); border-top: 1px solid rgba(255,255,255,0.04);">
    <div class="container display-flex justify-between align-center align-mobile-start gap-1">
      <h4 class="font-display m-0" style="font-size: 1.1rem; white-space: nowrap;" data-i18n="footer.newsletter_heading">Stay in the loop</h4>
      {%- form 'customer' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="flex-row">
          <input type="email" name="contact[email]" class="contact-input m-0" placeholder="Enter email address" required style="border-radius: 8px 0 0 8px; border-right: none;">
          <button type="submit" class="btn btn-purchase" style="border-radius: 0 8px 8px 0;" data-i18n="footer.newsletter_btn">Subscribe</button>
        </div>
      {%- endform -%}
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="footer-bottom pb-4 pt-4 px-4 text-muted font-body" style="font-size: 0.85rem; background-color: var(--color-surface-2); border-top: 1px solid rgba(255,255,255,0.06);">
    <div class="container display-flex justify-between align-center align-mobile-center flex-mobile-col gap-1">
      <p class="m-0">&copy; {{ 'now' | date: "%Y" }} SpeedCubeHub. All rights reserved.</p>
      <div class="payment-icons display-flex gap-0-5">
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'payment-icon', style: 'height: 24px; width: auto;' }}
        {%- else -%}
          <svg style="height:24px;width:auto;" viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" role="img" width="38" height="24" aria-labelledby="pi-visa"><title id="pi-visa">Visa</title><path opacity=".07" d="M35 0H3C1.3 0 0 1.3 0 3v18c0 1.7 1.4 3 3 3h32c1.7 0 3-1.3 3-3V3c0-1.7-1.4-3-3-3z"/><path fill="#fff" d="M35 1c1.1 0 2 .9 2 2v18c0 1.1-.9 2-2 2H3c-1.1 0-2-.9-2-2V3c0-1.1.9-2 2-2h32"/><path d="M28.3 10.1c-.2-.7-1.6-4.5-1.6-4.5h2.1l1.1 3.5 1-3.5h2l-2.4 7.6h-2.1l-.1-.1zm-8.8-.4c.3 1.9 1.7 2.4 2.8 2.4 1.5 0 2.2-.9 2.2-1.9 0-1.5-1.1-2.1-2.1-2.5-1.3-.6-1.6-1-1.6-1.6 0-.6.6-1.1 1.6-1.1 1.3 0 2.1.5 2.1.5l.3-1.4s-.8-.5-1.9-.5c-1.6 0-2.8.8-2.8 2 0 1.4 1.1 2 2.1 2.5 1.3.6 1.6 1.1 1.6 1.7 0 .6-.7 1.2-1.8 1.2-1.3 0-2.3-.6-2.3-.6l-.3 1.6zM15 17.6h-2l-1.9-7.6h2.2l1 5 1.3-4.9h2.1l-2.7 7.5zm-5-7.6h-2c-.3 0-.6.1-.8.4l-3 7.2h2.2s.3-.9.4-1.1h2.7c0 .1.2 1.1.2 1.1h2l-3.7-7.6zm-1.8 5l.9-2.5.5 2.5h-1.4z" fill="#142688"/></svg>
          <svg style="height:24px;width:auto;" viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" role="img" width="38" height="24" aria-labelledby="pi-master"><title id="pi-master">Mastercard</title><path opacity=".07" d="M35 0H3C1.3 0 0 1.3 0 3v18c0 1.7 1.4 3 3 3h32c1.7 0 3-1.3 3-3V3c0-1.7-1.4-3-3-3z"/><path fill="#fff" d="M35 1c1.1 0 2 .9 2 2v18c0 1.1-.9 2-2 2H3c-1.1 0-2-.9-2-2V3c0-1.1.9-2 2-2h32"/><path d="M22 17.3h3.5V6.7H22v10.6zM16.2 6.7C13.5 6.7 11 8 9.5 10c-1.5-2-4-3.3-6.7-3.3-4.6 0-8.3 3.7-8.3 8.3s3.7 8.3 8.3 8.3c2.7 0 5.2-1.3 6.7-3.3 1.5 2 4 3.3 6.7 3.3 4.6 0 8.3-3.7 8.3-8.3s-3.7-8.3-8.3-8.3zM9.5 15c-1 1.4-2.6 2.3-4.4 2.3-3.1 0-5.6-2.5-5.6-5.6s2.5-5.6 5.6-5.6c1.8 0 3.4.9 4.4 2.3-1 1.4-2.6 2.3-4.4 2.3z" fill="#ff5f00"/><path d="M16.2 9.4c-1 1.4-2.6 2.3-4.4 2.3-1.8 0-3.4-.9-4.4-2.3 1-1.4 2.6-2.3 4.4-2.3 1.8 0 3.4.9 4.4 2.3zM22 15c-1 1.4-2.6 2.3-4.4 2.3-3.1 0-5.6-2.5-5.6-5.6s2.5-5.6 5.6-5.6c1.8 0 3.4.9 4.4 2.3-1 1.4-2.6 2.3-4.4 2.3z" fill="#eb001b"/><path d="M22 15c-1 1.4-2.6 2.3-4.4 2.3-3.1 0-5.6-2.5-5.6-5.6s2.5-5.6 5.6-5.6c1.8 0 3.4.9 4.4 2.3-1 1.4-2.6 2.3-4.4 2.3z" fill="#f79e1b"/></svg>
        {%- endfor -%}
      </div>
    </div>
  </div>
</footer>

<style>
  .trust-bar__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: nowrap;
    overflow-x: auto;
    padding-bottom: 2px;
  }
  .trust-item {
    display: flex; align-items: center; gap: 0.75rem;
    flex: 1; justify-content: center;
    border-right: 1px solid rgba(255,255,255,0.05);
    padding: 0 1rem;
  }
  .trust-item.border-none { border-right: none; }
  .trust-item span { font-size: 0.95rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; color: var(--color-text); white-space: nowrap; }
  
  .footer { background-color: #060f1a; }
  .footer-grid {
    padding-top: 4rem; padding-bottom: 3rem;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 2rem;
  }
  
  .footer-col { display: flex; flex-direction: column; }
  .footer__socials { display: flex; gap: 1rem; margin-top: 1rem; }
  .social-icon { color: #8899AA; transition: color var(--transition-fast); }
  .social-icon:hover { color: var(--color-primary); }
  
  .footer-heading {
    text-transform: uppercase; letter-spacing: 1px; margin-bottom: 1.5rem;
    font-size: 1.1rem;
  }
  
  .footer-links { list-style: none; padding: 0; margin: 0; }
  .footer-links li { margin-bottom: 0.8rem; }
  .footer-links a { color: #8899AA; font-size: 0.95rem; transition: color var(--transition-fast); }
  .footer-links a:hover { color: var(--color-primary); }
  
  .display-flex { display: flex; }
  .justify-between { justify-content: space-between; }
  .align-center { align-items: center; }
  .flex-row { display: flex; flex-direction: row; }
  .gap-1 { gap: 1rem; }
  .gap-0-5 { gap: 0.5rem; }
  .m-0 { margin: 0 !important; }
  .px-4 { padding-left: 2rem; padding-right: 2rem; }
  .py-3 { padding-top: 1.5rem; padding-bottom: 1.5rem; }
  .pb-4 { padding-bottom: 2rem; }
  .pt-4 { padding-top: 2rem; }
  
  @media (max-width: 1024px) {
    .trust-item span { font-size: 0.8rem; }
  }
  @media (max-width: 768px) {
    .trust-bar__inner { flex-direction: column; gap: 1rem; align-items: flex-start; }
    .trust-item { border-right: none; width: 100%; justify-content: flex-start; }
    .footer-grid { grid-template-columns: 1fr; gap: 1rem; padding-top: 2rem; padding-bottom: 1rem; }
    .footer-col--brand { margin-bottom: 2rem; }
    
    .footer-col:not(.footer-col--brand) {
      border-top: 1px solid rgba(255,255,255,0.05);
      padding-top: 1rem;
    }
    .footer-heading { margin-bottom: 0.5rem; font-size: 1.2rem; cursor: pointer; display: flex; justify-content: space-between; }
    .footer-heading::after { content: '+'; font-weight: 400; color: #8899AA; }
    .footer-links { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
    .footer-col.is-open .footer-links { max-height: 300px; padding-top: 1rem; padding-bottom: 1rem; }
    .footer-col.is-open .footer-heading::after { content: '-'; }
    
    .align-mobile-start { flex-direction: column; align-items: flex-start; gap: 1rem; }
    .flex-mobile-col { flex-direction: column; text-align: center; }
    .align-mobile-center { align-items: center; justify-content: center; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    if(window.innerWidth <= 768) {
      const colHeadings = document.querySelectorAll('.footer-col:not(.footer-col--brand) .footer-heading');
      colHeadings.forEach(head => {
        head.addEventListener('click', () => {
          const col = head.parentElement;
          col.classList.toggle('is-open');
        });
      });
    }
  });
</script>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "brand_desc",
      "label": "Brand Description"
    }
  ]
}
{% endschema %}
