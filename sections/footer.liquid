<!-- Trust Bar -->
<div class="footer-trust-bar">
  <div class="container footer-trust__inner">
    <div class="footer-trust-item">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
      <span class="font-display footer-trust-label">Fast Shipping</span>
    </div>
    <div class="footer-trust-divider"></div>
    <div class="footer-trust-item">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1A9FE0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
      <span class="font-display footer-trust-label">Curated by Cubers</span>
    </div>
    <div class="footer-trust-divider"></div>
    <div class="footer-trust-item">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#FF6B1A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
      <span class="font-display footer-trust-label">Expert Support</span>
    </div>
    <div class="footer-trust-divider"></div>
    <div class="footer-trust-item">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
      <span class="font-display footer-trust-label">Secure Checkout</span>
    </div>
  </div>
</div>

<footer class="footer">
  <div class="container footer-grid">

    <!-- Brand -->
    <div class="footer-col footer-col--brand">
      {%- if settings.logo != blank -%}
        <img src="{{ settings.logo | image_url: width: 200 }}" alt="{{ shop.name | escape }}" style="max-height:40px;margin-bottom:1rem;display:block;">
      {%- else -%}
        <p class="font-display" style="font-size:1.5rem;font-weight:900;margin-bottom:1rem;">SpeedCubeHub</p>
      {%- endif -%}
      <p style="font-size:0.88rem;color:var(--color-text-muted);max-width:240px;line-height:1.7;margin-bottom:1.2rem;">
        {{ section.settings.brand_desc | default: "The home of the Middle East cubing community. Tested and approved by speedcubers." }}
      </p>
      <div class="footer__socials">
        <a href="#" class="social-icon" aria-label="Instagram">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </a>
        <a href="#" class="social-icon" aria-label="TikTok">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg>
        </a>
        <a href="#" class="social-icon" aria-label="YouTube">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.08C5.12 19.54 12 19.54 12 19.54s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.41z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg>
        </a>
      </div>
    </div>

    <!-- Shop -->
    <div class="footer-col">
      <h4 class="font-display footer-heading">Shop</h4>
      <ul class="footer-links">
        <li><a href="/collections/3x3">3x3 Cubes</a></li>
        <li><a href="/collections/2x2">2x2 Cubes</a></li>
        <li><a href="/collections/pyraminx">Pyraminx</a></li>
        <li><a href="/collections/megaminx">Megaminx</a></li>
        <li><a href="/collections/accessories">Accessories</a></li>
        <li><a href="/collections/all">All Products</a></li>
      </ul>
    </div>

    <!-- Brands -->
    <div class="footer-col">
      <h4 class="font-display footer-heading">Brands</h4>
      <ul class="footer-links">
        <li><a href="/collections/gan">GAN</a></li>
        <li><a href="/collections/moyu">MoYu</a></li>
        <li><a href="/collections/yj">YJ</a></li>
        <li><a href="/collections/qiyi">QiYi</a></li>
        <li><a href="/collections/dayan">DaYan</a></li>
        <li><a href="/collections/all">Other Brands</a></li>
      </ul>
    </div>

    <!-- Help -->
    <div class="footer-col">
      <h4 class="font-display footer-heading">Help</h4>
      <ul class="footer-links">
        <li><a href="/pages/faq">FAQ</a></li>
        <li><a href="/policies/shipping-policy">Shipping Policy</a></li>
        <li><a href="/policies/refund-policy">Returns</a></li>
        <li><a href="/pages/contact">Contact Us</a></li>
        <li><a href="/pages/about-us">About Us</a></li>
        <li><a href="/account">Track Order</a></li>
      </ul>
    </div>
  </div>

  <!-- Newsletter Band -->
  <div class="footer-newsletter">
    <div class="container footer-newsletter__inner">
      <p class="font-display footer-newsletter__label">Stay in the loop</p>
      {%- form 'customer' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="footer-newsletter__form">
          <input type="email" name="contact[email]" class="footer-newsletter__input" placeholder="Enter your email address" required>
          <button type="submit" class="btn btn-purchase footer-newsletter__btn">Subscribe</button>
        </div>
      {%- endform -%}
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="footer-bottom">
    <div class="container footer-bottom__inner">
      <p style="margin:0;font-size:0.85rem;color:var(--color-text-muted);">&copy; {{ 'now' | date: "%Y" }} SpeedCubeHub. All rights reserved.</p>
      <div class="footer-payment-icons">
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'payment-icon' }}
        {%- endfor -%}
      </div>
    </div>
  </div>
</footer>

<style>
  /* ── Trust bar ── */
  .footer-trust-bar {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 1.2rem 0;
  }
  .footer-trust__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
  }
  .footer-trust-item {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1;
    justify-content: center;
    padding: 0.5rem 1.5rem;
    min-width: 0;
  }
  .footer-trust-label {
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text);
    white-space: nowrap;
    line-height: 1;
  }
  .footer-trust-divider {
    width: 1px;
    height: 24px;
    background: var(--color-border);
    flex-shrink: 0;
  }
  @media (max-width: 900px) {
    .footer-trust__inner { flex-wrap: wrap; gap: 0.5rem; }
    .footer-trust-divider { display: none; }
    .footer-trust-item { min-width: 140px; justify-content: flex-start; padding: 0.5rem 1rem; }
  }
  @media (max-width: 480px) {
    .footer-trust__inner { display: grid; grid-template-columns: 1fr 1fr; }
    .footer-trust-item { border-bottom: 1px solid var(--color-border); padding: 0.8rem; }
    .footer-trust-item:nth-child(odd) { border-right: 1px solid var(--color-border); }
  }

  /* ── Footer main ── */
  .footer { background: #060f1a; }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 2.5rem;
    padding: 3.5rem 0 3rem;
  }
  @media (max-width: 900px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 2rem; padding: 2.5rem 0 2rem; }
    .footer-col--brand { grid-column: 1 / -1; }
  }
  @media (max-width: 560px) {
    .footer-grid { grid-template-columns: 1fr; gap: 0; padding: 1.5rem 0; }
  }

  .footer-col { display: flex; flex-direction: column; }
  .footer-col--brand { }
  .footer__socials { display: flex; gap: 0.8rem; }
  .social-icon { color: var(--color-text-muted); transition: color 0.2s; display: flex; }
  .social-icon:hover { color: var(--color-primary); }

  .footer-heading {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-primary);
    margin-bottom: 1.2rem;
    font-weight: 700;
  }
  .footer-links { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.7rem; }
  .footer-links a { color: var(--color-text-muted); font-size: 0.9rem; transition: color 0.2s, padding-left 0.2s; }
  .footer-links a:hover { color: var(--color-primary); padding-left: 4px; }

  /* Mobile accordion */
  @media (max-width: 560px) {
    .footer-col:not(.footer-col--brand) {
      border-top: 1px solid var(--color-border);
      padding: 1rem 0;
    }
    .footer-heading {
      display: flex; justify-content: space-between; align-items: center;
      cursor: pointer; margin-bottom: 0; padding: 0.5rem 0;
    }
    .footer-heading::after { content: '+'; font-size: 1.1rem; font-weight: 400; color: var(--color-text-muted); }
    .footer-col.is-open .footer-heading::after { content: '−'; }
    .footer-links { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; margin-top: 0; gap: 0; }
    .footer-col.is-open .footer-links { max-height: 300px; margin-top: 0.8rem; gap: 0.6rem; }
  }

  /* ── Newsletter ── */
  .footer-newsletter {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding: 1.8rem 0;
  }
  .footer-newsletter__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .footer-newsletter__label {
    font-size: 1.1rem;
    font-weight: 700;
    white-space: nowrap;
    margin: 0;
  }
  .footer-newsletter__form {
    display: flex;
    flex: 1;
    min-width: 260px;
    max-width: 480px;
  }
  .footer-newsletter__input {
    flex: 1;
    padding: 12px 16px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-right: none;
    border-radius: 8px 0 0 8px;
    color: var(--color-text);
    font-size: 0.9rem;
    width: auto;
  }
  .footer-newsletter__input:focus { outline: none; border-color: var(--color-primary); }
  .footer-newsletter__btn {
    border-radius: 0 8px 8px 0;
    padding: 12px 20px;
    white-space: nowrap;
    min-height: auto;
  }
  @media (max-width: 600px) {
    .footer-newsletter__inner { flex-direction: column; align-items: stretch; }
    .footer-newsletter__form { max-width: 100%; }
  }

  /* ── Bottom bar ── */
  .footer-bottom {
    background: #040c14;
    border-top: 1px solid rgba(255,255,255,0.05);
    padding: 1.2rem 0;
  }
  .footer-bottom__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .footer-payment-icons { display: flex; align-items: center; gap: 6px; }
  .payment-icon { height: 24px; width: auto; }
  @media (max-width: 600px) {
    .footer-bottom__inner { justify-content: center; flex-direction: column; text-align: center; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    if (window.innerWidth <= 560) {
      document.querySelectorAll('.footer-col:not(.footer-col--brand) .footer-heading').forEach(h => {
        h.addEventListener('click', () => h.closest('.footer-col').classList.toggle('is-open'));
      });
    }
  });
</script>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "textarea", "id": "brand_desc", "label": "Brand Description" }
  ]
}
{% endschema %}
