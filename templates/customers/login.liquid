<div class="customer-page container section" style="max-width: 500px; margin: 4rem auto;">
  <div class="auth-card" style="background-color: var(--color-surface); padding: 3rem; border-radius: var(--border-radius); border: 1px solid rgba(255,255,255,0.07); box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
    
    <div id="RecoverPasswordForm" class="hide" style="display: none;">
      <div class="text-center mb-4">
        <h1 class="font-display color-primary mb-2">Reset Password</h1>
        <p class="font-body text-muted">We will send you an email to reset your password.</p>
      </div>

      {%- form 'recover_customer_password' -%}
        {%- if form.posted_successfully? -%}
          <p class="form-success" style="color: var(--color-success); margin-bottom: 1rem;">We've sent you an email with a link to update your password.</p>
        {%- endif -%}
        <div style="color: var(--color-error); margin-bottom: 1rem;">{{ form.errors | default_errors }}</div>
        
        <div class="form-group mb-4" style="margin-bottom: 1.5rem;">
          <input type="email" name="email" id="RecoverEmail" placeholder="Email Address" required class="contact-input" autocorrect="off" autocapitalize="off">
        </div>
        
        <div class="text-center">
          <button type="submit" class="btn btn-purchase btn--full mb-4">Submit</button>
          <a href="#LoginHeading" onclick="document.getElementById('RecoverPasswordForm').style.display='none'; document.getElementById('CustomerLoginForm').style.display='block'; return false;" class="font-body color-accent">Cancel</a>
        </div>
      {%- endform -%}
    </div>

    <div id="CustomerLoginForm">
      <div class="text-center mb-4">
        <h1 id="LoginHeading" class="font-display color-primary mb-2">Sign In</h1>
        <p class="font-body text-muted">Welcome back to SpeedCubeHub.</p>
      </div>

      {%- form 'customer_login' -%}
        <div style="color: var(--color-error); margin-bottom: 1rem;">{{ form.errors | default_errors }}</div>
        
        <div class="form-group mb-4" style="margin-bottom: 1rem;">
          <input type="email" name="customer[email]" id="CustomerEmail" placeholder="Email Address" required class="contact-input" autocorrect="off" autocapitalize="off" autocomplete="email">
        </div>

        {%- if form.password_needed -%}
          <div class="form-group mb-4" style="margin-bottom: 1.5rem;">
            <input type="password" name="customer[password]" id="CustomerPassword" placeholder="Password" required class="contact-input">
            <div class="mt-2 text-right">
              <a href="#recover" onclick="document.getElementById('RecoverPasswordForm').style.display='block'; document.getElementById('CustomerLoginForm').style.display='none'; return false;" class="font-body text-muted" style="font-size: 0.9rem;">Forgot password?</a>
            </div>
          </div>
        {%- endif -%}

        <button type="submit" class="btn btn-purchase btn--full mb-4">Sign In</button>
        
        <div class="text-center mt-4">
          <p class="font-body text-muted">New to SpeedCubeHub? <a href="{{ routes.account_register_url }}" class="color-accent font-body" style="font-weight: 700;">Create account</a></p>
        </div>
      {%- endform -%}
    </div>
  </div>
</div>
