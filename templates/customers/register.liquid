<div class="customer-page container section" style="max-width: 500px; margin: 4rem auto;">
  <div class="auth-card" style="background-color: var(--color-surface); padding: 3rem; border-radius: var(--border-radius); border: 1px solid rgba(255,255,255,0.07); box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
    <div class="text-center mb-4">
      <h1 class="font-display color-primary mb-2">Create Account</h1>
      <p class="font-body text-muted">Join the fastest-growing cubing community.</p>
    </div>

    {%- form 'create_customer' -%}
      <div style="color: var(--color-error); margin-bottom: 1rem;">{{ form.errors | default_errors }}</div>
      
      <div class="form-group mb-4" style="margin-bottom: 1rem;">
        <input type="text" name="customer[first_name]" id="RegisterForm-FirstName" placeholder="First Name" class="contact-input" {% if form.first_name %}value="{{ form.first_name }}"{% endif %} autocomplete="given-name">
      </div>
      
      <div class="form-group mb-4" style="margin-bottom: 1rem;">
        <input type="text" name="customer[last_name]" id="RegisterForm-LastName" placeholder="Last Name" class="contact-input" {% if form.last_name %}value="{{ form.last_name }}"{% endif %} autocomplete="family-name">
      </div>

      <div class="form-group mb-4" style="margin-bottom: 1rem;">
        <input type="email" name="customer[email]" id="RegisterForm-email" placeholder="Email Address" required class="contact-input" autocorrect="off" autocapitalize="off" autocomplete="email" {% if form.email %} value="{{ form.email }}"{% endif %}>
      </div>

      <div class="form-group mb-4" style="margin-bottom: 1.5rem;">
        <input type="password" name="customer[password]" id="RegisterForm-password" placeholder="Password" required class="contact-input">
      </div>

      <button type="submit" class="btn btn-purchase btn--full mb-4">Create Account</button>
      
      <div class="text-center mt-4">
        <p class="font-body text-muted">Already have an account? <a href="{{ routes.account_login_url }}" class="color-accent font-body" style="font-weight: 700;">Sign in</a></p>
      </div>
    {%- endform -%}
  </div>
</div>
