{{ 'theme.css' | asset_url | stylesheet_tag }}

<div class="cart-page section">
  <div class="container">
    <div class="cart-page__header">
      <h1 class="font-display cart-page__title">Your Cart</h1>
      <a href="{{ routes.all_products_collection_url }}" class="cart-page__continue">← Continue Shopping</a>
    </div>

    {%- if cart.item_count > 0 -%}
      <div class="cart-page__layout">

        <!-- Items -->
        <div class="cart-page__items">
          {%- for item in cart.items -%}
            <div class="cart-page-item" data-line="{{ forloop.index }}">
              <a href="{{ item.url }}" class="cart-page-item__img-wrap">
                {%- if item.image -%}
                  <img src="{{ item.image | image_url: width: 300 }}" alt="{{ item.title | escape }}" class="cart-page-item__img" loading="lazy">
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'cart-page-item__img cart-page-item__img--placeholder' }}
                {%- endif -%}
              </a>

              <div class="cart-page-item__details">
                <div class="cart-page-item__top">
                  <div>
                    <a href="{{ item.url }}" class="cart-page-item__title">{{ item.product.title }}</a>
                    {%- unless item.variant.title == 'Default Title' -%}
                      <div class="cart-page-item__variant">{{ item.variant.title }}</div>
                    {%- endunless -%}
                    {%- if item.vendor -%}
                      <div class="cart-page-item__vendor">{{ item.vendor }}</div>
                    {%- endif -%}
                  </div>
                  <div class="cart-page-item__line-price">{{ item.final_line_price | money }}</div>
                </div>

                <div class="cart-page-item__bottom">
                  <div class="cart-page-item__unit-price">{{ item.price | money }} each</div>
                  <div class="cart-page-item__actions">
                    <div class="cart-page-qty">
                      <button class="cart-page-qty__btn cart-page-qty-minus" data-line="{{ forloop.index }}" aria-label="Decrease">−</button>
                      <span class="cart-page-qty-val">{{ item.quantity }}</span>
                      <button class="cart-page-qty__btn cart-page-qty-plus" data-line="{{ forloop.index }}" aria-label="Increase">+</button>
                    </div>
                    <button class="cart-page-remove" data-line="{{ forloop.index }}" aria-label="Remove item">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6l-1 14H6L5 6"></path><path d="M10 11v6M14 11v6"></path></svg>
                      Remove
                    </button>
                  </div>
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>

        <!-- Summary -->
        <div class="cart-page__summary">
          <div class="cart-summary-box">
            <h2 class="font-display cart-summary-box__title">Order Summary</h2>

            <div class="cart-summary-box__free-shipping">
              {%- assign free_threshold = 36700 -%}
              {%- assign pct = cart.total_price | times: 100 | divided_by: free_threshold -%}
              {%- if cart.total_price >= free_threshold -%}
                <p class="cart-summary-box__shipping-msg">🎉 <strong style="color:var(--color-primary)">You qualify for free shipping!</strong></p>
              {%- else -%}
                {%- assign remaining = free_threshold | minus: cart.total_price -%}
                <p class="cart-summary-box__shipping-msg">Add <strong style="color:var(--color-primary)">{{ remaining | money }}</strong> more for free shipping</p>
              {%- endif -%}
              <div class="cart-summary-box__progress-track">
                <div class="cart-summary-box__progress-fill" style="width: {{ pct | at_most: 100 }}%"></div>
              </div>
            </div>

            <div class="cart-summary-box__lines">
              <div class="cart-summary-box__line">
                <span>Subtotal ({{ cart.item_count }} item{% if cart.item_count != 1 %}s{% endif %})</span>
                <span>{{ cart.total_price | money }}</span>
              </div>
              <div class="cart-summary-box__line cart-summary-box__line--muted">
                <span>Shipping</span>
                <span>Calculated at checkout</span>
              </div>
            </div>

            <div class="cart-summary-box__total">
              <span class="font-display">Total</span>
              <span class="font-display cart-summary-box__total-price">{{ cart.total_price | money }}</span>
            </div>

            <form action="{{ routes.cart_url }}" method="post">
              <button type="submit" name="checkout" class="btn btn-purchase btn--full cart-summary-box__checkout">
                Proceed to Checkout
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </button>
            </form>

            <div class="cart-summary-box__trust">
              <div class="cart-trust-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                <span>Secure Checkout</span>
              </div>
              <div class="cart-trust-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
                <span>Fast UAE Delivery</span>
              </div>
              <div class="cart-trust-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><polyline points="3 3 3 8 8 8"></polyline></svg>
                <span>Easy Returns</span>
              </div>
            </div>
          </div>
        </div>

      </div>

    {%- else -%}
      <div class="cart-page__empty">
        <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity:0.2;display:block;margin:0 auto 1.5rem;"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
        <h2 class="font-display" style="margin-bottom:1rem;">Your cart is empty</h2>
        <p style="color:var(--color-text-muted);margin-bottom:2rem;">Looks like you haven't added anything yet.</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn-primary">Start Shopping</a>
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .cart-page { padding: 3rem 0 5rem; }
  .cart-page__header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 2.5rem; flex-wrap: wrap; gap: 1rem; }
  .cart-page__title { font-size: clamp(1.8rem, 4vw, 2.8rem); margin: 0; }
  .cart-page__continue { color: var(--color-text-muted); text-decoration: none; font-size: 0.9rem; transition: color 0.2s; }
  .cart-page__continue:hover { color: var(--color-primary); }

  .cart-page__layout { display: grid; grid-template-columns: 1fr 380px; gap: 2.5rem; align-items: start; }
  @media (max-width: 900px) { .cart-page__layout { grid-template-columns: 1fr; } }

  /* Cart Item */
  .cart-page__items { display: flex; flex-direction: column; gap: 1rem; }
  .cart-page-item {
    display: flex; gap: 1.2rem; align-items: flex-start;
    background: var(--color-surface); border: 1px solid var(--color-border);
    border-radius: 14px; padding: 1.2rem; transition: border-color 0.2s;
  }
  .cart-page-item:hover { border-color: rgba(255,208,0,0.2); }
  .cart-page-item__img-wrap { flex-shrink: 0; width: 100px; height: 100px; border-radius: 8px; overflow: hidden; background: var(--color-bg); display: flex; align-items: center; justify-content: center; }
  .cart-page-item__img { width: 100%; height: 100%; object-fit: contain; padding: 6px; }
  .cart-page-item__details { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 0.7rem; }
  .cart-page-item__top { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; }
  .cart-page-item__title { font-family: var(--font-display); font-weight: 700; font-size: 1rem; color: var(--color-text); text-decoration: none; transition: color 0.2s; line-height: 1.3; }
  .cart-page-item__title:hover { color: var(--color-primary); }
  .cart-page-item__variant, .cart-page-item__vendor { font-size: 0.8rem; color: var(--color-text-muted); margin-top: 2px; }
  .cart-page-item__line-price { font-family: var(--font-display); font-weight: 900; font-size: 1.1rem; color: var(--color-primary); white-space: nowrap; flex-shrink: 0; }
  .cart-page-item__bottom { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
  .cart-page-item__unit-price { font-size: 0.8rem; color: var(--color-text-muted); }
  .cart-page-item__actions { display: flex; align-items: center; gap: 1rem; }

  /* Qty controls on cart page */
  .cart-page-qty {
    display: flex; align-items: center;
    border: 1.5px solid var(--color-border); border-radius: 8px;
    background: var(--color-bg); overflow: hidden;
  }
  .cart-page-qty__btn {
    background: none; border: none; color: var(--color-text);
    width: 34px; height: 34px; cursor: pointer; font-size: 1.1rem;
    transition: all 0.2s; display: flex; align-items: center; justify-content: center;
  }
  .cart-page-qty__btn:hover { background: var(--color-surface); color: var(--color-primary); }
  .cart-page-qty-val { min-width: 28px; text-align: center; font-family: var(--font-display); font-weight: 700; font-size: 0.95rem; color: var(--color-text); }
  .cart-page-remove {
    background: none; border: none; color: var(--color-text-muted); cursor: pointer;
    font-size: 0.8rem; display: flex; align-items: center; gap: 4px; transition: color 0.2s; padding: 0;
  }
  .cart-page-remove:hover { color: #ef4444; }

  /* Summary box */
  .cart-summary-box {
    background: var(--color-surface); border: 1px solid var(--color-border);
    border-radius: 16px; padding: 1.8rem; position: sticky; top: 84px;
  }
  .cart-summary-box__title { font-size: 1.3rem; margin: 0 0 1.2rem; }
  .cart-summary-box__free-shipping { margin-bottom: 1.2rem; padding-bottom: 1.2rem; border-bottom: 1px solid var(--color-border); }
  .cart-summary-box__shipping-msg { font-size: 0.88rem; color: var(--color-text-muted); margin-bottom: 0.6rem; }
  .cart-summary-box__progress-track { height: 5px; background: var(--color-bg); border-radius: 3px; overflow: hidden; }
  .cart-summary-box__progress-fill { height: 100%; background: var(--color-primary); border-radius: 3px; transition: width 0.5s ease; }
  .cart-summary-box__lines { display: flex; flex-direction: column; gap: 0.7rem; margin-bottom: 1.2rem; padding-bottom: 1.2rem; border-bottom: 1px solid var(--color-border); }
  .cart-summary-box__line { display: flex; justify-content: space-between; font-size: 0.9rem; color: var(--color-text); }
  .cart-summary-box__line--muted span { color: var(--color-text-muted); }
  .cart-summary-box__total { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
  .cart-summary-box__total-price { font-size: 1.6rem; color: var(--color-primary); }
  .cart-summary-box__checkout { width: 100%; margin-bottom: 1.2rem; justify-content: center; gap: 8px; }
  .cart-summary-box__trust { display: flex; flex-direction: column; gap: 0.5rem; padding-top: 1rem; border-top: 1px solid var(--color-border); }
  .cart-trust-item { display: flex; align-items: center; gap: 0.5rem; font-size: 0.8rem; color: var(--color-text-muted); }

  /* Empty state */
  .cart-page__empty { text-align: center; padding: 5rem 0; }

  @media (max-width: 600px) {
    .cart-page-item__img-wrap { width: 76px; height: 76px; }
    .cart-page-item { padding: 1rem; }
    .cart-summary-box { position: static; }
  }
</style>
