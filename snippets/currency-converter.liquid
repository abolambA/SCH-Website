{% comment %}
  Currency Converter Snippet - SpeedCubeHub
  - Store base currency: USD
  - GCC countries: shows local currency with +5% markup
  - Others: shows USD (no conversion needed)
  - All prices use psychological .99 pricing
{% endcomment %}

<script>
(function() {
  // Exchange rates - 1 USD = x local currency
  const USD_RATES = {
    'AED': 3.67,
    'SAR': 3.75,
    'KWD': 0.308,
    'QAR': 3.64,
    'BHD': 0.377,
    'OMR': 0.385,
  };
  
  const GCC_COUNTRIES = {
    'AE': 'AED', 'SA': 'SAR', 'KW': 'KWD',
    'QA': 'QAR', 'BH': 'BHD', 'OM': 'OMR',
  };
  
  const CURRENCY_SYMBOLS = {
    'AED': 'AED', 'SAR': 'SAR', 'KWD': 'KD',
    'QAR': 'QAR', 'BHD': 'BD', 'OMR': 'OMR',
  };
  
const DECIMALS = { 'KWD': 3, 'BHD': 3, 'OMR': 3, 'default': 2 };
  
  // +5% markup for GCC to secure profit margin
  const GCC_MARKUP = 1.05;
  
  function detectCountry() {
    const stored = localStorage.getItem('sch_currency_country');
    if (stored) return stored;
    const c = window.Shopify && (window.Shopify.country || (window.Shopify.locale && window.Shopify.locale.country));
    if (c) { localStorage.setItem('sch_currency_country', c); return c; }
    return null;
  }
  
  // Apply psychological .99 pricing: round to nearest integer then subtract 0.01
  // For currencies with 3 decimal places (KWD, BHD, OMR), subtract 0.001 instead
  function applyDotNineNine(amount, dec) {
    if (amount <= 0) return amount;
    if (dec === 3) {
      // e.g. 4.123 KWD -> round to 4 -> 3.999 KWD
      const rounded = Math.round(amount);
      return Math.max(0, rounded - 0.001);
    } else {
      // e.g. 52.48 AED -> round to 52 -> 51.99 AED
      const rounded = Math.round(amount);
      return Math.max(0, rounded - 0.01);
    }
  }
  
  function formatPrice(amount, currency) {
    const dec = DECIMALS[currency] || DECIMALS['default'];
    const sym = CURRENCY_SYMBOLS[currency] || currency;
    const psychoAmount = applyDotNineNine(amount, dec);
    const parts = psychoAmount.toFixed(dec).split('.');
    parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    return parts.join('.') + ' ' + sym;
  }
  
  function convertAll() {
    const country = detectCountry();
    if (!country) return;
    const currency = GCC_COUNTRIES[country];
    if (!currency) return;
    
    window.SCH_currency = { from: 'USD', to: currency, country: country, isGCC: true };
    
    const rate = USD_RATES[currency] * GCC_MARKUP;
    
    const selectors = [
      '.price', '.price__regular', '.price__sale',
      '[data-product-price]', '.product-card__price',
      '.product__price', '.product-form__price',
      '.cart-item__price', '.money',
      '.cart-summary-box__total-price',
      '.cart-page-item__line-price', '.cart-page-item__unit-price'
    ].join(',');
    
    document.querySelectorAll(selectors).forEach(el => {
      if (el.dataset.schConverted) return;
      el.dataset.schConverted = '1';
      const text = el.textContent.trim();
      const match = text.match(/\$([\d,]+\.?\d*)/);
      if (match) {
        const usd = parseFloat(match[1].replace(/,/g, ''));
        if (!isNaN(usd) && usd > 0) {
          el.setAttribute('data-usd', text);
          el.textContent = formatPrice(usd * rate, currency);
        }
      }
    });
  }
  
  function init() {
    convertAll();
    const obs = new MutationObserver(convertAll);
    obs.observe(document.body, { childList: true, subtree: true });
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else { init(); }
})();
</script>