{% comment %}
  Currency Converter Snippet
  - Detects visitor country via Shopify's built-in locale
  - Shows prices in local currency for GCC countries (with 5% markup)
  - Shows prices in USD for international visitors
  - Default store currency is AED (UAE Dirham)
{% endcomment %}

<script>
(function() {
  // Fixed exchange rates (AED as base)
  // These rates should be updated periodically
  // 1 AED = x [currency]
  const AED_RATES = {
    'AED': 1,           // UAE Dirham (base)
    'SAR': 1.020,       // Saudi Riyal (1 AED ≈ 1.02 SAR)
    'KWD': 0.083,       // Kuwaiti Dinar (1 AED ≈ 0.083 KWD)
    'QAR': 1.000,       // Qatari Riyal (1 AED ≈ 1.00 QAR)
    'BHD': 0.103,       // Bahraini Dinar (1 AED ≈ 0.103 BHD)
    'OMR': 0.105,       // Omani Rial (1 AED ≈ 0.105 OMR)
    'USD': 0.272,       // US Dollar (1 AED ≈ 0.272 USD = 3.67 AED/USD)
    'SYP': 3425,        // Syrian Pound (approximate)
  };
  
  const GCC_COUNTRIES = {
    'AE': 'AED',  // UAE
    'SA': 'SAR',  // Saudi Arabia
    'KW': 'KWD',  // Kuwait
    'QA': 'QAR',  // Qatar
    'BH': 'BHD',  // Bahrain
    'OM': 'OMR',  // Oman
  };
  
  const CURRENCY_SYMBOLS = {
    'AED': 'AED',
    'SAR': 'SAR',
    'KWD': 'KD',
    'QAR': 'QAR',
    'BHD': 'BD',
    'OMR': 'OMR',
    'USD': '$',
    'SYP': 'SYP',
  };
  
  const CURRENCY_DECIMALS = {
    'KWD': 3,
    'BHD': 3,
    'OMR': 3,
    'USD': 2,
    'default': 2
  };
  
  // GCC MARKUP: +5% over standard conversion
  const GCC_MARKUP = 1.05;
  
  // Detect country from Shopify locale or stored preference
  function detectCountry() {
    // Check stored preference
    const stored = localStorage.getItem('sch_currency_country');
    if (stored) return stored;
    
    // Use Shopify's built-in country detection
    const shopifyCountry = window.Shopify?.country || window.Shopify?.locale?.country;
    if (shopifyCountry) {
      localStorage.setItem('sch_currency_country', shopifyCountry);
      return shopifyCountry;
    }
    
    return null;
  }
  
  function getCurrencyForCountry(country) {
    if (!country) return 'USD';  // Default to USD for unknown
    if (country === 'AE') return 'AED';  // UAE stays AED
    if (country === 'SY') return 'AED';  // Syria also shows AED (or SYP but impractical)
    return GCC_COUNTRIES[country] || 'USD';  // GCC countries get local, others get USD
  }
  
  function convertPrice(aedPrice, targetCurrency, isGCC) {
    const rate = AED_RATES[targetCurrency] || AED_RATES['USD'];
    let converted = aedPrice * rate;
    if (isGCC && targetCurrency !== 'AED') {
      converted *= GCC_MARKUP;  // +5% for GCC (non-AED)
    }
    return converted;
  }
  
  function formatPrice(amount, currency) {
    const decimals = CURRENCY_DECIMALS[currency] || CURRENCY_DECIMALS['default'];
    const symbol = CURRENCY_SYMBOLS[currency] || currency;
    const rounded = Math.round(amount * Math.pow(10, decimals)) / Math.pow(10, decimals);
    return symbol + ' ' + rounded.toFixed(decimals);
  }
  
  // Convert all price elements on the page
  function convertAllPrices() {
    const country = detectCountry();
    const targetCurrency = getCurrencyForCountry(country);
    
    // If target is AED, no conversion needed (that's the store currency)
    if (targetCurrency === 'AED') return;
    
    const isGCC = country && GCC_COUNTRIES[country] && targetCurrency !== 'AED';
    
    // Store conversion info globally
    window.SCH_currency = {
      from: 'AED',
      to: targetCurrency,
      country: country,
      isGCC: isGCC
    };
    
    // Find all price elements
    const priceSelectors = [
      '.price',
      '.price__regular',
      '.price__sale',
      '[data-product-price]',
      '.product-card__price',
      '.product-price',
      '.product-form__price',
      '.cart-item__price',
      '.cart-subtotal',
      '.order-summary__price',
      '.money'
    ];
    
    const priceElements = document.querySelectorAll(priceSelectors.join(','));
    
    priceElements.forEach(el => {
      if (el.dataset.schConverted) return;
      el.dataset.schConverted = '1';
      
      // Extract AED price from text
      const text = el.textContent.trim();
      // Look for price pattern like "AED 195.00" or "Dhs. 195.00"
      const match = text.match(/(?:AED|Dhs?\.?\s*)\s*([\d,]+\.?\d*)/i);
      if (match) {
        const aedAmount = parseFloat(match[1].replace(',', ''));
        if (!isNaN(aedAmount)) {
          const converted = convertPrice(aedAmount, targetCurrency, isGCC);
          el.textContent = formatPrice(converted, targetCurrency);
        }
      }
    });
  }
  
  // Run conversion when DOM is ready
  function init() {
    convertAllPrices();
    
    // Re-run on dynamic content changes (for cart updates, etc.)
    const observer = new MutationObserver(function(mutations) {
      mutations.forEach(function(mutation) {
        if (mutation.addedNodes.length > 0) {
          convertAllPrices();
        }
      });
    });
    
    observer.observe(document.body, { childList: true, subtree: true });
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>