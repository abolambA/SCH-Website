<div class="product-card tilt-enabled reveal {% if product.available == false %}soldout{% endif %}">
  {% if product.available == false %}
    <div class="soldout-overlay">Sold Out</div>
  {% endif %}
  <div class="product-card__inner">
    <a href="{{ product.url | default: '#' }}" class="product-card__link">
      <div class="product-card__image-wrapper">
        {%- if product.featured_image -%}
          <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}" loading="lazy" class="product-card__image">
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'product-card__image' }}
        {%- endif -%}

        <div class="product-card__badges">
          {%- if product.compare_at_price > product.price -%}
            {% render 'badge', type: 'sale', text: 'SALE' %}
          {%- endif -%}
          {%- if product.tags contains 'New' -%}
            {% render 'badge', type: 'new', text: 'NEW' %}
          {%- endif -%}
        </div>

        <div class="product-card__quick-add">
          <button class="btn btn-purchase btn--full" onclick="event.preventDefault(); CartDrawer.addProduct({{ product.variants.first.id }}, 1, this)">
            Quick Add
          </button>
        </div>
      </div>

      <div class="product-card__info">
        <h3 class="product-card__title">{{ product.title | default: 'Example Speedcube M' }}</h3>
        <div class="product-card__prices">
          <span class="product-card__price">{{ product.price | default: 8900 | money }}</span>
          {%- if product.compare_at_price > product.price -%}
            <span class="product-card__compare-price">{{ product.compare_at_price | money }}</span>
          {%- endif -%}
        </div>
      </div>
    </a>
  </div>
</div>

<style>
  .product-card {
    perspective: 1000px;
    height: 100%;
    margin-bottom: 2rem;
    position: relative;
  }

  .product-card__inner {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    height: 100%;
    transition: transform 0.1s ease-out, box-shadow 0.1s ease-out;
    transform-style: preserve-3d;
    overflow: hidden;
    position: relative;
    z-index: 1;
  }

  .product-card__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    color: inherit;
  }

  .product-card__image-wrapper {
    position: relative;
    padding: 1rem;
    background-color: var(--color-bg);
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .product-card__image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform var(--transition-slow);
  }

  .product-card:hover .product-card__image {
    transform: scale(1.05);
  }

  .product-card__badges {
    position: absolute;
    top: 1rem;
    left: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    z-index: 2;
  }

  .product-card__quick-add {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 1rem;
    transform: translateY(100%);
    transition: transform var(--transition-fast);
    z-index: 2;
  }

  .product-card:hover .product-card__quick-add {
    transform: translateY(0);
  }

  .product-card__info {
    padding: 1.5rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .product-card__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-text);
    margin-bottom: 0.8rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.3;
  }

  .product-card__prices {
    display: flex;
    align-items: baseline;
    gap: 0.8rem;
  }

  .product-card__price {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.2rem;
    color: var(--color-primary);
  }

  .product-card__compare-price {
    font-size: 0.9rem;
    color: var(--color-secondary);
    text-decoration: line-through;
  }
</style>
